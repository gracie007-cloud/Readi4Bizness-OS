                            <input type="text" id="canvasTitle" class="form-control" placeholder="My Document" value="My Document">
                        </div>
                        <div class="form-group">
                            <label for="autoSave">Auto-save Interval (seconds)</label>
                            <input type="number" id="autoSave" class="form-control" value="30" min="10" max="300">
