        <!-- Footer -->
        <footer>
            <div class="container">
                <p>Readi4Bizness OS - Digital Product Business Operating System</p>
                <p>Static version with localStorage state management | Demo credentials: demo@readi4bizness.com / readi-demo-2026</p>
            </div>
        </footer>
    </div>

    <script>
        // App state and initialization
        document.addEventListener('DOMContentLoaded', function() {
            // Check if user is already logged in
            const isLoggedIn = localStorage.getItem('readi4bizness_loggedIn');
            const currentUser = localStorage.getItem('readi4bizness_user');
            
            if (isLoggedIn === 'true' && currentUser) {
                showApp(currentUser);
            } else {
                showLoginModal();
            }
            
            // Initialize all modules
            initLoginForm();
            initNavigation();
            initDashboard();
            initBlueprintModule();
            initResearchModule();
            initProductModule();
            initContentModule();
            initAdsModule();
            initCanvasModule();
        });
        
        // Login functionality
        function showLoginModal() {
            document.getElementById('loginModal').style.display = 'flex';
            document.getElementById('app').style.display = 'none';
        }
        
        function showApp(user) {
            document.getElementById('loginModal').style.display = 'none';
            document.getElementById('app').style.display = 'block';
            document.getElementById('currentUser').textContent = user;
            
            // Update dashboard with saved data
            updateDashboard();
        }
        
        function initLoginForm() {
            const loginForm = document.getElementById('loginForm');
            
            loginForm.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const email = document.getElementById('email').value;
                const password = document.getElementById('password').value;
                
                // Check demo credentials
                if (email === 'demo@readi4bizness.com' && password === 'readi-demo-2026') {
                    // Save login state
                    localStorage.setItem('readi4bizness_loggedIn', 'true');
                    localStorage.setItem('readi4bizness_user', email);
                    
                    showApp(email);
                    
                    // Log activity
                    logActivity('User logged in');
                } else {
                    alert('Invalid credentials. Please use the demo credentials provided.');
                }
            });
        }
        
        // Logout functionality
        document.getElementById('logoutBtn').addEventListener('click', function() {
            localStorage.removeItem('readi4bizness_loggedIn');
            localStorage.removeItem('readi4bizness_user');
            
            // Clear form fields
            document.getElementById('email').value = '';
            document.getElementById('password').value = '';
            
            showLoginModal();
        });
        
        // Navigation
        function initNavigation() {
            const navLinks = document.querySelectorAll('.nav-link');
            
            navLinks.forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    // Update active nav link
                    navLinks.forEach(l => l.classList.remove('active'));
                    this.classList.add('active');
                    
                    // Show corresponding module
                    const moduleId = this.getAttribute('data-module');
                    showModule(moduleId);
                });
            });
        }
        
        function showModule(moduleId) {
            // Hide all modules
            document.querySelectorAll('.module').forEach(module => {
                module.classList.remove('active');
            });
            
            // Show selected module
            document.getElementById(moduleId).classList.add('active');
            
            // Log activity
            logActivity(`Navigated to ${moduleId} module`);
        }
        
        // Dashboard functionality
        function initDashboard() {
            updateDashboard();
            
            // Load activity log from localStorage
            loadActivityLog();
        }
        
        function updateDashboard() {
            // Update dashboard status cards from localStorage
            const blueprint = localStorage.getItem('readi4bizness_blueprint');
            const researchScans = JSON.parse(localStorage.getItem('readi4bizness_researchScans') || '[]');
            const products = JSON.parse(localStorage.getItem('readi4bizness_products') || '[]');
            const contentPlan = JSON.parse(localStorage.getItem('readi4bizness_contentPlan') || '[]');
            
            document.getElementById('blueprintStatus').textContent = blueprint ? 'Completed' : 'Not Started';
            document.getElementById('researchStatus').textContent = `${researchScans.length} Scan${researchScans.length !== 1 ? 's' : ''}`;
            document.getElementById('productStatus').textContent = products.length;
            document.getElementById('contentStatus').textContent = `${contentPlan.length} Item${contentPlan.length !== 1 ? 's' : ''}`;
            
            // Update status badges
            const blueprintStatus = document.querySelector('#blueprintStatus').nextElementSibling;
            blueprintStatus.textContent = blueprint ? 'Complete' : 'Pending';
            blueprintStatus.className = `status ${blueprint ? 'status-good' : 'status-warning'}`;
            
            const researchStatus = document.querySelector('#researchStatus').nextElementSibling;
            researchStatus.textContent = researchScans.length > 0 ? 'Active' : 'Pending';
            researchStatus.className = `status ${researchScans.length > 0 ? 'status-good' : 'status-warning'}`;
            
            const productStatus = document.querySelector('#productStatus').nextElementSibling;
            productStatus.textContent = products.length > 0 ? 'Active' : 'Pending';
            productStatus.className = `status ${products.length > 0 ? 'status-good' : 'status-warning'}`;
            
            const contentStatus = document.querySelector('#contentStatus').nextElementSibling;
            contentStatus.textContent = contentPlan.length > 0 ? 'Active' : 'Pending';
            contentStatus.className = `status ${contentPlan.length > 0 ? 'status-good' : 'status-warning'}`;
        }
        
        function logActivity(activity) {
            const activities = JSON.parse(localStorage.getItem('readi4bizness_activities') || '[]');
            const newActivity = {
                date: new Date().toLocaleString(),
                activity: activity,
                status: 'Completed'
            };
            
            activities.unshift(newActivity);
            
            // Keep only last 10 activities
            if (activities.length > 10) {
                activities.pop();
            }
            
            localStorage.setItem('readi4bizness_activities', JSON.stringify(activities));
            loadActivityLog();
        }
        
        function loadActivityLog() {
            const activities = JSON.parse(localStorage.getItem('readi4bizness_activities') || '[]');
            const activityLog = document.getElementById('activityLog');
            
            activityLog.innerHTML = '';
            
            if (activities.length === 0) {
                activityLog.innerHTML = '<tr><td colspan="3" style="text-align: center;">No recent activity</td></tr>';
                return;
            }
            
            activities.forEach(activity => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${activity.date}</td>
                    <td>${activity.activity}</td>
                    <td><span class="status status-good">${activity.status}</span></td>
                `;
                activityLog.appendChild(row);
            });
        }
        
        // Blueprint Module
        function initBlueprintModule() {
            const blueprintForm = document.getElementById('blueprintForm');
            const clearBlueprintBtn = document.getElementById('clearBlueprint');
            const loadBlueprintBtn = document.getElementById('loadBlueprint');
            const exportBlueprintBtn = document.getElementById('exportBlueprint');
            
            // Load saved blueprint if exists
            loadSavedBlueprint();
            
            blueprintForm.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const blueprintData = {
                    name: document.getElementById('bizName').value,
                    tagline: document.getElementById('bizTagline').value,
                    targetAudience: document.getElementById('targetAudience').value,
                    valueProposition: document.getElementById('valueProposition').value,
                    revenueModel: document.getElementById('revenueModel').value,
                    goals: document.getElementById('bizGoals').value,
                    date: new Date().toLocaleString()
                };
                
                // Generate blueprint output
                const output = `
BUSINESS BLUEPRINT
==================
Business Name: ${blueprintData.name || 'Not specified'}
Tagline: ${blueprintData.tagline || 'Not specified'}

TARGET AUDIENCE
---------------
${blueprintData.targetAudience || 'Not specified'}

VALUE PROPOSITION
-----------------
${blueprintData.valueProposition || 'Not specified'}

REVENUE MODEL
-------------
${blueprintData.revenueModel ? blueprintData.revenueModel.charAt(0).toUpperCase() + blueprintData.revenueModel.slice(1) : 'Not specified'}

SHORT-TERM GOALS
----------------
${blueprintData.goals || 'Not specified'}

Generated: ${blueprintData.date}
                `;
                
                // Show output
                document.getElementById('blueprintContent').textContent = output;
                document.getElementById('blueprintOutput').style.display = 'block';
                
                // Save to localStorage
                localStorage.setItem('readi4bizness_blueprint', JSON.stringify(blueprintData));
                
                // Update dashboard
                updateDashboard();
                
                // Log activity
                logActivity('Business blueprint generated');
            });
            
            clearBlueprintBtn.addEventListener('click', function() {
                blueprintForm.reset();
                document.getElementById('blueprintOutput').style.display = 'none';
            });
            
            loadBlueprintBtn.addEventListener('click', loadSavedBlueprint);
            
            exportBlueprintBtn.addEventListener('click', function() {
                const content = document.getElementById('blueprintContent').textContent;
                exportAsTextFile(content, 'business-blueprint.txt');
            });
        }
        
        function loadSavedBlueprint() {
            const saved = localStorage.getItem('readi4bizness_blueprint');
            
            if (saved) {
                const blueprintData = JSON.parse(saved);
                
                document.getElementById('bizName').value = blueprintData.name || '';
                document.getElementById('bizTagline').value = blueprintData.tagline || '';
                document.getElementById('targetAudience').value = blueprintData.targetAudience || '';
                document.getElementById('valueProposition').value = blueprintData.valueProposition || '';
                document.getElementById('revenueModel').value = blueprintData.revenueModel || '';
                document.getElementById('bizGoals').value = blueprintData.goals || '';
                
                // Generate output
                const output = `
BUSINESS BLUEPRINT
==================
Business Name: ${blueprintData.name || 'Not specified'}
Tagline: ${blueprintData.tagline || 'Not specified'}

TARGET AUDIENCE
---------------
${blueprintData.targetAudience || 'Not specified'}

VALUE PROPOSITION
-----------------
${blueprintData.valueProposition || 'Not specified'}

REVENUE MODEL
-------------
${blueprintData.revenueModel ? blueprintData.revenueModel.charAt(0).toUpperCase() + blueprintData.revenueModel.slice(1) : 'Not specified'}

SHORT-TERM GOALS
----------------
${blueprintData.goals || 'Not specified'}

Generated: ${blueprintData.date}
                `;
                
                document.getElementById('blueprintContent').textContent = output;
                document.getElementById('blueprintOutput').style.display = 'block';
            }
        }
        
        // Research Module
        function initResearchModule() {
            const researchForm = document.getElementById('researchForm');
            const clearResearchBtn = document.getElementById('clearResearch');
            const saveResearchBtn = document.getElementById('saveResearch');
            
            // Update range value displays
            document.getElementById('marketDemand').addEventListener('input', function() {
                document.getElementById('demandValue').textContent = this.value;
            });
            
            document.getElementById('competitionLevel').addEventListener('input', function() {
                document.getElementById('competitionValue').textContent = this.value;
            });
            
            researchForm.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const researchData = {
                    idea: document.getElementById('productIdea').value,
                    category: document.getElementById('productCategory').value,
                    marketDemand: document.getElementById('marketDemand').value,
                    competition: document.getElementById('competitionLevel').value,
                    uniqueSellingPoint: document.getElementById('uniqueSellingPoint').value
                };
                
                // Calculate viability score (simple algorithm)
                const demandScore = parseInt(researchData.marketDemand);
                const competitionScore = 11 - parseInt(researchData.competition); // Lower competition is better
                const viabilityScore = Math.round(((demandScore + competitionScore) / 20) * 100);
                
                // Generate research output
                const output = `
DIGITAL PRODUCT VIABILITY SCAN
==============================
Product Idea: ${researchData.idea || 'Not specified'}
Category: ${researchData.category ? researchData.category.charAt(0).toUpperCase() + researchData.category.slice(1) : 'Not specified'}

ANALYSIS
--------
Market Demand: ${researchData.marketDemand}/10
Competition Level: ${researchData.competition}/10
Unique Selling Point: ${researchData.uniqueSellingPoint || 'Not specified'}

VIABILITY SCORE: ${viabilityScore}/100
${viabilityScore >= 70 ? '✓ HIGH VIABILITY - This product has strong potential!' : 
  viabilityScore >= 40 ? '◉ MODERATE VIABILITY - Consider refining your approach.' : 
  '✗ LOW VIABILITY - This product may struggle in the current market.'}

RECOMMENDATIONS
---------------
${viabilityScore >= 70 ? '- Proceed with product development\n- Focus on marketing and audience building\n- Consider premium pricing strategy' : 
  viabilityScore >= 40 ? '- Research competitors more thoroughly\n- Strengthen your unique selling proposition\n- Consider a different pricing model' : 
  '- Reconsider the product concept\n- Explore different market segments\n- Develop a stronger unique value proposition'}

Scan Date: ${new Date().toLocaleString()}
                `;
                
                // Show output
                document.getElementById('researchContent').textContent = output;
                document.getElementById('researchOutput').style.display = 'block';
                
                // Save scan temporarily (until user clicks save)
                researchForm.tempData = researchData;
                researchForm.tempOutput = output;
                researchForm.tempViability = viabilityScore;
                
                // Log activity
                logActivity('Viability scan performed');
            });
            
            clearResearchBtn.addEventListener('click', function() {
                researchForm.reset();
                document.getElementById('demandValue').textContent = '5';
                document.getElementById('competitionValue').textContent = '5';
                document.getElementById('researchOutput').style.display = 'none';
            });
            
            saveResearchBtn.addEventListener('click', function() {
                const researchForm = document.getElementById('researchForm');
                
                if (!researchForm.tempData) {
                    alert('Please run a viability scan first.');
                    return;
                }
                
                const scans = JSON.parse(localStorage.getItem('readi4bizness_researchScans') || '[]');
                
                const scanToSave = {
                    ...researchForm.tempData,
                    output: researchForm.tempOutput,
                    viability: researchForm.tempViability,
                    date: new Date().toLocaleString()
                };
                
                scans.unshift(scanToSave);
                localStorage.setItem('readi4bizness_researchScans', JSON.stringify(scans));
                
                // Update dashboard
                updateDashboard();
                
                // Show saved scans
                displaySavedScans();
                
                // Log activity
                logActivity('Viability scan saved');
                
                alert('Scan saved successfully!');
            });
            
            // Display saved scans if any
            displaySavedScans();
        }
        
        function displaySavedScans() {
            const scans = JSON.parse(localStorage.getItem('readi4bizness_researchScans') || '[]');
            const scansList = document.getElementById('scansList');
            
            if (scans.length === 0) {
                document.getElementById('savedScans').style.display = 'none';
                return;
            }
            
            document.getElementById('savedScans').style.display = 'block';
            
            let html = '<table><thead><tr><th>Product Idea</th><th>Category</th><th>Viability</th><th>Date</th><th>Action</th></tr></thead><tbody>';
            
            scans.forEach((scan, index) => {
                html += `
                <tr>
                    <td>${scan.idea || 'Not specified'}</td>
                    <td>${scan.category ? scan.category.charAt(0).toUpperCase() + scan.category.slice(1) : 'Not specified'}</td>
                    <td><span class="status ${scan.viability >= 70 ? 'status-good' : scan.viability >= 40 ? 'status-warning' : 'status-warning'}">${scan.viability}/100</span></td>
                    <td>${scan.date}</td>
                    <td><button class="btn btn-secondary" style="padding: 5px 10px; font-size: 0.8rem;" onclick="viewScan(${index})">View</button></td>
                </tr>
                `;
            });
            
            html += '</tbody></table>';
            scansList.innerHTML = html;
        }
        
        // Make viewScan available globally
        window.viewScan = function(index) {
            const scans = JSON.parse(localStorage.getItem('readi4bizness_researchScans') || '[]');
            
            if (scans[index]) {
                document.getElementById('researchContent').textContent = scans[index].output;
                document.getElementById('researchOutput').style.display = 'block';
                
                // Scroll to research output
                document.getElementById('researchOutput').scrollIntoView({ behavior: 'smooth' });
            }
        };
        
        // Product Module
        function initProductModule() {
            const productForm = document.getElementById('productForm');
            const clearProductBtn = document.getElementById('clearProduct');
            const exportProductBtn = document.getElementById('exportProduct');
            
            productForm.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const productData = {
                    name: document.getElementById('productName').value,
                    price: document.getElementById('productPrice').value,
                    description: document.getElementById('productDescription').value,
                    features: document.getElementById('productFeatures').value,
                    format: document.getElementById('deliveryFormat').value
                };
                
                // Generate product packaging output
                const featuresList = productData.features.split('\n').filter(f => f.trim()).map(f => `• ${f.trim()}`).join('\n');
                
                const output = `
PRODUCT PACKAGING OUTPUT
=======================
Product Name: ${productData.name || 'Not specified'}
Price: ${productData.price ? '$' + parseFloat(productData.price).toFixed(2) : 'Not specified'}

DESCRIPTION
-----------
${productData.description || 'Not specified'}

KEY FEATURES
------------
${featuresList || 'Not specified'}

DELIVERY FORMAT
---------------
${productData.format ? productData.format.charAt(0).toUpperCase() + productData.format.slice(1) : 'Not specified'}

PACKAGING SUMMARY
-----------------
${productData.name || 'This product'} is priced at ${productData.price ? '$' + parseFloat(productData.price).toFixed(2) : 'TBD'} and will be delivered as ${productData.format || 'digital content'}.
${productData.features.split('\n').filter(f => f.trim()).length} key features have been identified.

Generated: ${new Date().toLocaleString()}
                `;
                
                // Show output
                document.getElementById('productContent').textContent = output;
                document.getElementById('productOutput').style.display = 'block';
                
                // Save to localStorage
                const products = JSON.parse(localStorage.getItem('readi4bizness_products') || '[]');
                products.unshift({
                    ...productData,
                    output: output,
                    date: new Date().toLocaleString()
                });
                localStorage.setItem('readi4bizness_products', JSON.stringify(products));
                
                // Update dashboard
                updateDashboard();
                
                // Log activity
                logActivity('Product packaging generated');
            });
            
            clearProductBtn.addEventListener('click', function() {
                productForm.reset();
                document.getElementById('productOutput').style.display = 'none';
            });
            
            exportProductBtn.addEventListener('click', function() {
                const content = document.getElementById('productContent').textContent;
                exportAsTextFile(content, 'product-packaging.txt');
            });
        }
        
        // Content Module
        function initContentModule() {
            const contentForm = document.getElementById('contentForm');
            const clearContentBtn = document.getElementById('clearContent');
            
            // Load saved content plan
            loadContentPlan();
            
            contentForm.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const contentItem = {
                    id: Date.now(),
                    title: document.getElementById('contentTitle').value,
                    type: document.getElementById('contentType').value,
                    topic: document.getElementById('contentTopic').value,
                    dueDate: document.getElementById('contentDueDate').value,
                    outline: document.getElementById('contentOutline').value,
                    status: 'Planned'
                };
                
                // Save to localStorage
                const contentPlan = JSON.parse(localStorage.getItem('readi4bizness_contentPlan') || '[]');
                contentPlan.unshift(contentItem);
                localStorage.setItem('readi4bizness_contentPlan', JSON.stringify(contentPlan));
                
                // Reload content plan
                loadContentPlan();
                
                // Clear form
                contentForm.reset();
                
                // Update dashboard
                updateDashboard();
                
                // Log activity
                logActivity('Content item added to plan');
            });
            
            clearContentBtn.addEventListener('click', function() {
                contentForm.reset();
            });
        }
        
        function loadContentPlan() {
            const contentPlan = JSON.parse(localStorage.getItem('readi4bizness_contentPlan') || '[]');
            const contentPlanList = document.getElementById('contentPlanList');
            
            contentPlanList.innerHTML = '';
            
            if (contentPlan.length === 0) {
                contentPlanList.innerHTML = '<tr><td colspan="6" style="text-align: center;">No content items planned yet</td></tr>';
                return;
            }
            
            contentPlan.forEach(item => {
                const row = document.createElement('tr');
                
                // Format date
                const dueDate = item.dueDate ? new Date(item.dueDate).toLocaleDateString() : 'Not set';
                
                row.innerHTML = `
                    <td>${item.title || 'Untitled'}</td>
                    <td>${item.type ? item.type.charAt(0).toUpperCase() + item.type.slice(1) : 'Not specified'}</td>
                    <td>${item.topic || 'Not specified'}</td>
                    <td>${dueDate}</td>
                    <td><span class="status ${item.status === 'Completed' ? 'status-good' : 'status-warning'}">${item.status}</span></td>
                    <td>
                        <button class="btn btn-secondary" style="padding: 5px 10px; font-size: 0.8rem;" onclick="toggleContentStatus(${item.id})">
                            ${item.status === 'Completed' ? 'Mark Planned' : 'Mark Complete'}
                        </button>
                        <button class="btn btn-secondary" style="padding: 5px 10px; font-size: 0.8rem;" onclick="deleteContentItem(${item.id})">Delete</button>
                    </td>
                `;
                
                contentPlanList.appendChild(row);
            });
        }
        
        // Make content functions available globally
        window.toggleContentStatus = function(id) {
            const contentPlan = JSON.parse(localStorage.getItem('readi4bizness_contentPlan') || '[]');
            
            const itemIndex = contentPlan.findIndex(item => item.id === id);
            
            if (itemIndex !== -1) {
                contentPlan[itemIndex].status = contentPlan[itemIndex].status === 'Completed' ? 'Planned' : 'Completed';
                localStorage.setItem('readi4bizness_contentPlan', JSON.stringify(contentPlan));
                loadContentPlan();
                
                // Log activity
                logActivity(`Content item "${contentPlan[itemIndex].title}" marked as ${contentPlan[itemIndex].status}`);
            }
        };
        
        window.deleteContentItem = function(id) {
            if (confirm('Are you sure you want to delete this content item?')) {
                const contentPlan = JSON.parse(localStorage.getItem('readi4bizness_contentPlan') || '[]');
                const filteredPlan = contentPlan.filter(item => item.id !== id);
                localStorage.setItem('readi4bizness_contentPlan', JSON.stringify(filteredPlan));
                loadContentPlan();
                
                // Update dashboard
                updateDashboard();
                
                // Log activity
                logActivity('Content item deleted');
            }
        };
        
        // Ads Module
        function initAdsModule() {
            const adsForm = document.getElementById('adsForm');
            const clearAdsBtn = document.getElementById('clearAds');
            
            // Load saved campaigns
            loadAdsPlan();
            
            adsForm.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const campaignItem = {
                    id: Date.now(),
                    name: document.getElementById('campaignName').value,
                    type: document.getElementById('campaignType').value,
                    budget: document.getElementById('budget').value,
                    startDate: document.getElementById('startDate').value,
                    goal: document.getElementById('campaignGoal').value,
                    status: 'Planned'
                };
                
                // Save to localStorage
                const adsPlan = JSON.parse(localStorage.getItem('readi4bizness_adsPlan') || '[]');
                adsPlan.unshift(campaignItem);
                localStorage.setItem('readi4bizness_adsPlan', JSON.stringify(adsPlan));
                
                // Reload ads plan
                loadAdsPlan();
                
                // Clear form
                adsForm.reset();
                
                // Log activity
                logActivity('Campaign added to plan');
            });
            
            clearAdsBtn.addEventListener('click', function() {
                adsForm.reset();
            });
        }
        
        function loadAdsPlan() {
            const adsPlan = JSON.parse(localStorage.getItem('readi4bizness_adsPlan') || '[]');
            const adsPlanList = document.getElementById('adsPlanList');
            
            adsPlanList.innerHTML = '';
            
            if (adsPlan.length === 0) {
                adsPlanList.innerHTML = '<tr><td colspan="6" style="text-align: center;">No campaigns planned yet</td></tr>';
                return;
            }
            
            adsPlan.forEach(item => {
                const row = document.createElement('tr');
                
                // Format date
                const startDate = item.startDate ? new Date(item.startDate).toLocaleDateString() : 'Not set';
                
                row.innerHTML = `
                    <td>${item.name || 'Untitled'}</td>
                    <td>${item.type ? item.type.charAt(0).toUpperCase() + item.type.slice(1) : 'Not specified'}</td>
                    <td>${item.budget ? '$' + parseFloat(item.budget).toFixed(2) : 'Not set'}</td>
                    <td>${startDate}</td>
                    <td><span class="status ${item.status === 'Active' ? 'status-good' : 'status-warning'}">${item.status}</span></td>
                    <td>
                        <button class="btn btn-secondary" style="padding: 5px 10px; font-size: 0.8rem;" onclick="toggleCampaignStatus(${item.id})">
                            ${item.status === 'Active' ? 'Mark Inactive' : 'Mark Active'}
                        </button>
                        <button class="btn btn-secondary" style="padding: 5px 10px; font-size: 0.8rem;" onclick="deleteCampaign(${item.id})">Delete</button>
                    </td>
                `;
                
                adsPlanList.appendChild(row);
            });
        }
        
        // Make campaign functions available globally
        window.toggleCampaignStatus = function(id) {
            const adsPlan = JSON.parse(localStorage.getItem('readi4bizness_adsPlan') || '[]');
            
            const itemIndex = adsPlan.findIndex(item => item.id === id);
            
            if (itemIndex !== -1) {
                adsPlan[itemIndex].status = adsPlan[itemIndex].status === 'Active' ? 'Inactive' : 'Active';
                localStorage.setItem('readi4bizness_adsPlan', JSON.stringify(adsPlan));
                loadAdsPlan();
                
                // Log activity
                logActivity(`Campaign "${adsPlan[itemIndex].name}" marked as ${adsPlan[itemIndex].status}`);
            }
        };
        
        window.deleteCampaign = function(id) {
            if (confirm('Are you sure you want to delete this campaign?')) {
                const adsPlan = JSON.parse(localStorage.getItem('readi4bizness_adsPlan') || '[]');
                const filteredPlan = adsPlan.filter(item => item.id !== id);
                localStorage.setItem('readi4bizness_adsPlan', JSON.stringify(filteredPlan));
                loadAdsPlan();
                
                // Log activity
                logActivity('Campaign deleted');
            }
        };
        
        // Canvas Module
        function initCanvasModule() {
            const canvasArea = document.getElementById('canvasArea');
            const boldBtn = document.getElementById('boldBtn');
            const italicBtn = document.getElementById('italicBtn');
            const underlineBtn = document.getElementById('underlineBtn');
            const clearCanvasBtn = document.getElementById('clearCanvas');
            const exportCanvasBtn = document.getElementById('exportCanvas');
            const saveCanvasNowBtn = document.getElementById('saveCanvasNow');
            const loadCanvasBtn = document.getElementById('loadCanvas');
            
            // Load saved canvas content
            loadCanvasContent();
            
            // Auto-save functionality
            let autoSaveInterval;
            const autoSaveInput = document.getElementById('autoSave');
            
            function startAutoSave() {
                const interval = parseInt(autoSaveInput.value) * 1000;
                
                if (autoSaveInterval) {
                    clearInterval(autoSaveInterval);
                }
                
                autoSaveInterval = setInterval(() => {
                    saveCanvasContent();
                }, interval);
            }
            
            // Start auto-save with initial value
            startAutoSave();
            
            // Update auto-save interval when input changes
            autoSaveInput.addEventListener('change', startAutoSave);
            
            // Formatting buttons
            boldBtn.addEventListener('click', () => document.execCommand('bold'));
            italicBtn.addEventListener('click', () => document.execCommand('italic'));
            underlineBtn.addEventListener('click', () => document.execCommand('underline'));
            
            // Clear canvas
            clearCanvasBtn.addEventListener('click', function() {
                if (confirm('Are you sure you want to clear the canvas? This cannot be undone.')) {
                    canvasArea.innerHTML = '<p></p>';
                    localStorage.removeItem('readi4bizness_canvasContent');
                    localStorage.removeItem('readi4bizness_canvasTitle');
                }
            });
            
            // Export canvas content
            exportCanvasBtn.addEventListener('click', function() {
                const title = document.getElementById('canvasTitle').value || 'My Document';
                const content = canvasArea.innerText;
                exportAsTextFile(content, `${title}.txt`);
            });
            
            // Save canvas now
            saveCanvasNowBtn.addEventListener('click', saveCanvasContent);
            
            // Load saved canvas
            loadCanvasBtn.addEventListener('click', loadCanvasContent);
            
            // Save canvas content to localStorage
            function saveCanvasContent() {
                const title = document.getElementById('canvasTitle').value || 'My Document';
                const content = canvasArea.innerHTML;
                
                localStorage.setItem('readi4bizness_canvasContent', content);
                localStorage.setItem('readi4bizness_canvasTitle', title);
                
                // Log activity (but not too frequently)
                if (!saveCanvasContent.lastLog || Date.now() - saveCanvasContent.lastLog > 60000) {
                    logActivity('Canvas document saved');
                    saveCanvasContent.lastLog = Date.now();
                }
            }
            
            // Load canvas content from localStorage
            function loadCanvasContent() {
                const savedContent = localStorage.getItem('readi4bizness_canvasContent');
                const savedTitle = localStorage.getItem('readi4bizness_canvasTitle');
                
                if (savedContent) {
                    canvasArea.innerHTML = savedContent;
                }
                
                if (savedTitle) {
                    document.getElementById('canvasTitle').value = savedTitle;
                }
            }
            
            // Save on input
            canvasArea.addEventListener('input', function() {
                // Debounce save to avoid too many saves
                clearTimeout(canvasArea.saveTimeout);
                canvasArea.saveTimeout = setTimeout(saveCanvasContent, 2000);
            });
        }
        
        // Utility function to export content as text file
        function exportAsTextFile(content, filename) {
            const blob = new Blob([content], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            
            // Log activity
            logActivity(`Exported ${filename}`);
        }
    </script>
</body>
</html>
