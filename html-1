<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Readi4Bizness OS - Digital Product Business Operating System</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #2563eb;
            --primary-dark: #1d4ed8;
            --secondary-color: #0ea5e9;
            --success-color: #10b981;
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-300: #d1d5db;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --gray-900: #111827;
            --border-radius: 8px;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--gray-50);
            color: var(--gray-800);
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Header & Navigation */
        header {
            background-color: white;
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary-color);
        }

        .logo i {
            font-size: 1.8rem;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 20px;
        }

        nav a {
            text-decoration: none;
            color: var(--gray-700);
            font-weight: 500;
            padding: 8px 12px;
            border-radius: var(--border-radius);
            transition: var(--transition);
        }

        nav a:hover, nav a.active {
            background-color: var(--primary-color);
            color: white;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logout-btn {
            background-color: var(--gray-200);
            border: none;
            padding: 8px 15px;
            border-radius: var(--border-radius);
            cursor: pointer;
            transition: var(--transition);
        }

        .logout-btn:hover {
            background-color: var(--gray-300);
        }

        /* Login Modal */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal {
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 450px;
            padding: 30px;
            animation: modalFadeIn 0.3s ease;
        }

        @keyframes modalFadeIn {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .modal-header {
            text-align: center;
            margin-bottom: 25px;
        }

        .modal-header h2 {
            color: var(--primary-color);
            margin-bottom: 10px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid var(--gray-300);
            border-radius: var(--border-radius);
            font-size: 1rem;
            transition: var(--transition);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

        .btn {
            display: inline-block;
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: var(--border-radius);
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            text-align: center;
        }

        .btn:hover {
            background-color: var(--primary-dark);
        }

        .btn-block {
            width: 100%;
        }

        .demo-credentials {
            background-color: var(--gray-100);
            padding: 15px;
            border-radius: var(--border-radius);
            margin-top: 20px;
            font-size: 0.9rem;
        }

        .demo-credentials p {
            margin-bottom: 5px;
        }

        /* Main Content */
        main {
            padding: 30px 0;
        }

        .module {
            display: none;
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            padding: 30px;
            margin-bottom: 30px;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .module.active {
            display: block;
        }

        .module-header {
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--gray-200);
        }

        .module-header h2 {
            color: var(--primary-color);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .module-header h2 i {
            font-size: 1.5rem;
        }

        /* Dashboard */
        .status-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .status-card {
            background-color: var(--gray-50);
            border-radius: var(--border-radius);
            padding: 20px;
            border-left: 4px solid var(--primary-color);
        }

        .status-card h3 {
            font-size: 1rem;
            color: var(--gray-700);
            margin-bottom: 10px;
        }

        .status-card .value {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--gray-900);
        }

        .status-card .status {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
            margin-top: 10px;
        }

        .status-good {
            background-color: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
        }

        .status-warning {
            background-color: rgba(245, 158, 11, 0.1);
            color: var(--warning-color);
        }

        /* Forms */
        .form-row {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        textarea {
            min-height: 150px;
            resize: vertical;
        }

        /* Output Section */
        .output-section {
            background-color: var(--gray-50);
            border-radius: var(--border-radius);
            padding: 20px;
            margin-top: 30px;
            border: 1px dashed var(--gray-300);
        }

        .output-section h3 {
            margin-bottom: 15px;
            color: var(--gray-700);
        }

        .output-content {
            background-color: white;
            padding: 15px;
            border-radius: var(--border-radius);
            border: 1px solid var(--gray-200);
            min-height: 100px;
            max-height: 300px;
            overflow-y: auto;
            white-space: pre-wrap;
        }

        /* Canvas */
        .canvas-container {
            display: flex;
            flex-direction: column;
            height: 500px;
        }

        .canvas-toolbar {
            display: flex;
            gap: 10px;
            padding: 10px;
            background-color: var(--gray-100);
            border-radius: var(--border-radius) var(--border-radius) 0 0;
            border: 1px solid var(--gray-200);
            border-bottom: none;
        }

        .canvas-area {
            flex: 1;
            padding: 20px;
            border: 1px solid var(--gray-200);
            border-radius: 0 0 var(--border-radius) var(--border-radius);
            overflow-y: auto;
            background-color: white;
        }

        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid var(--gray-200);
        }

        th {
            background-color: var(--gray-50);
            font-weight: 600;
        }

        tr:hover {
            background-color: var(--gray-50);
        }

        /* Action Buttons */
        .actions {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .btn-secondary {
            background-color: var(--gray-200);
            color: var(--gray-700);
        }

        .btn-secondary:hover {
            background-color: var(--gray-300);
        }

        .btn-success {
            background-color: var(--success-color);
        }

        .btn-success:hover {
            background-color: #0da271;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 20px 0;
            color: var(--gray-700);
            font-size: 0.9rem;
            border-top: 1px solid var(--gray-200);
            margin-top: 30px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header-content {
                flex-direction: column;
                gap: 15px;
            }
            
            nav ul {
                flex-wrap: wrap;
                justify-content: center;
            }
            
            .form-row {
                grid-template-columns: 1fr;
            }
            
            .status-cards {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Login Modal -->
    <div id="loginModal" class="modal-overlay">
        <div class="modal">
            <div class="modal-header">
                <h2>Readi4Bizness OS</h2>
                <p>Enter your credentials to access the operating system</p>
            </div>
            <form id="loginForm">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" class="form-control" placeholder="demo@readi4bizness.com" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" class="form-control" placeholder="readi-demo-2026" required>
                </div>
                <button type="submit" class="btn btn-block">Login</button>
                
                <div class="demo-credentials">
                    <p><strong>Demo Credentials:</strong></p>
                    <p>Email: demo@readi4bizness.com</p>
                    <p>Password: readi-demo-2026</p>
                </div>
            </form>
        </div>
    </div>

    <!-- Main App (hidden until login) -->
    <div id="app" style="display: none;">
        <!-- Header -->
        <header>
            <div class="container">
                <div class="header-content">
                    <div class="logo">
                        <i class="fas fa-rocket"></i>
                        <span>Readi4Bizness OS</span>
                    </div>
                    
                    <nav>
                        <ul>
                            <li><a href="#" class="nav-link active" data-module="dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a href="#" class="nav-link" data-module="blueprint"><i class="fas fa-project-diagram"></i> Blueprint</a></li>
                            <li><a href="#" class="nav-link" data-module="research"><i class="fas fa-search"></i> Research</a></li>
                            <li><a href="#" class="nav-link" data-module="product"><i class="fas fa-box-open"></i> Product Maker</a></li>
                            <li><a href="#" class="nav-link" data-module="content"><i class="fas fa-pen-fancy"></i> Content</a></li>
                            <li><a href="#" class="nav-link" data-module="ads"><i class="fas fa-ad"></i> Ads & Affiliates</a></li>
                            <li><a href="#" class="nav-link" data-module="canvas"><i class="fas fa-paint-brush"></i> Canvas</a></li>
                        </ul>
                    </nav>
                    
                    <div class="user-info">
                        <span id="currentUser">demo@readi4bizness.com</span>
                        <button id="logoutBtn" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</button>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="container">
            <!-- Dashboard Module -->
            <section id="dashboard" class="module active">
                <div class="module-header">
                    <h2><i class="fas fa-tachometer-alt"></i> Internal Dashboard</h2>
                    <p>Overview of your business operating status</p>
                </div>
                
                <div class="status-cards">
                    <div class="status-card">
                        <h3>Business Blueprint</h3>
                        <div class="value" id="blueprintStatus">Not Started</div>
                        <div class="status status-warning">Pending</div>
                    </div>
                    
                    <div class="status-card">
                        <h3>Product Research</h3>
                        <div class="value" id="researchStatus">0 Scans</div>
                        <div class="status status-warning">Pending</div>
                    </div>
                    
                    <div class="status-card">
                        <h3>Products Packaged</h3>
                        <div class="value" id="productStatus">0</div>
                        <div class="status status-warning">Pending</div>
                    </div>
                    
                    <div class="status-card">
                        <h3>Content Planned</h3>
                        <div class="value" id="contentStatus">0 Items</div>
                        <div class="status status-warning">Pending</div>
                    </div>
                </div>
                
                <h3>Recent Activity</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Activity</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="activityLog">
                        <!-- Activity will be populated by JavaScript -->
                    </tbody>
                </table>
            </section>

            <!-- Business Blueprint Generator Module -->
            <section id="blueprint" class="module">
                <div class="module-header">
                    <h2><i class="fas fa-project-diagram"></i> Business Blueprint Generator</h2>
                    <p>Create your business blueprint by filling out the form below</p>
                </div>
                
                <form id="blueprintForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="bizName">Business Name</label>
                            <input type="text" id="bizName" class="form-control" placeholder="Enter business name">
                        </div>
                        <div class="form-group">
                            <label for="bizTagline">Tagline</label>
                            <input type="text" id="bizTagline" class="form-control" placeholder="Enter business tagline">
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="targetAudience">Target Audience</label>
                            <textarea id="targetAudience" class="form-control" placeholder="Describe your ideal customer"></textarea>
                        </div>
                        <div class="form-group">
                            <label for="valueProposition">Value Proposition</label>
                            <textarea id="valueProposition" class="form-control" placeholder="What unique value do you provide?"></textarea>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="revenueModel">Revenue Model</label>
                            <select id="revenueModel" class="form-control">
                                <option value="">Select revenue model</option>
                                <option value="subscription">Subscription</option>
                                <option value="onetime">One-time Purchase</option>
                                <option value="freemium">Freemium</option>
                                <option value="ads">Advertising</option>
                                <option value="affiliate">Affiliate Marketing</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="bizGoals">Business Goals (short-term)</label>
                            <textarea id="bizGoals" class="form-control" placeholder="List your short-term business goals"></textarea>
                        </div>
                    </div>
                    
                    <div class="actions">
                        <button type="submit" class="btn">Generate Blueprint</button>
                        <button type="button" id="clearBlueprint" class="btn btn-secondary">Clear Form</button>
                        <button type="button" id="loadBlueprint" class="btn btn-secondary">Load Saved</button>
                    </div>
                </form>
                
                <div class="output-section" id="blueprintOutput" style="display: none;">
                    <h3>Generated Blueprint</h3>
                    <div class="output-content" id="blueprintContent"></div>
                    <div class="actions">
                        <button type="button" id="exportBlueprint" class="btn btn-success"><i class="fas fa-download"></i> Export as Text</button>
                    </div>
                </div>
            </section>

            <!-- Digital Product Research Module -->
            <section id="research" class="module">
                <div class="module-header">
                    <h2><i class="fas fa-search"></i> Digital Product Research Viability Scan</h2>
                    <p>Analyze the viability of your digital product ideas</p>
                </div>
                
                <form id="researchForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="productIdea">Product Idea</label>
                            <input type="text" id="productIdea" class="form-control" placeholder="Enter your product idea">
                        </div>
                        <div class="form-group">
                            <label for="productCategory">Category</label>
                            <select id="productCategory" class="form-control">
                                <option value="">Select category</option>
                                <option value="ebook">E-Book</option>
                                <option value="course">Online Course</option>
                                <option value="software">Software/Tool</option>
                                <option value="template">Template</option>
                                <option value="membership">Membership Site</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="marketDemand">Market Demand (1-10)</label>
                            <input type="range" id="marketDemand" class="form-control" min="1" max="10" value="5">
                            <div style="display: flex; justify-content: space-between;">
                                <span>Low</span>
                                <span id="demandValue">5</span>
                                <span>High</span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="competitionLevel">Competition Level (1-10)</label>
                            <input type="range" id="competitionLevel" class="form-control" min="1" max="10" value="5">
                            <div style="display: flex; justify-content: space-between;">
                                <span>Low</span>
                                <span id="competitionValue">5</span>
                                <span>High</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="uniqueSellingPoint">Unique Selling Point</label>
                        <textarea id="uniqueSellingPoint" class="form-control" placeholder="What makes your product unique?"></textarea>
                    </div>
                    
                    <div class="actions">
                        <button type="submit" class="btn">Run Viability Scan</button>
                        <button type="button" id="clearResearch" class="btn btn-secondary">Clear Form</button>
                    </div>
                </form>
                
                <div class="output-section" id="researchOutput" style="display: none;">
                    <h3>Viability Scan Results</h3>
                    <div class="output-content" id="researchContent"></div>
                    <div class="actions">
                        <button type="button" id="saveResearch" class="btn btn-success"><i class="fas fa-save"></i> Save Scan</button>
                    </div>
                </div>
                
                <div class="output-section" id="savedScans" style="display: none;">
                    <h3>Saved Scans</h3>
                    <div id="scansList"></div>
                </div>
            </section>

            <!-- Product Maker Module -->
            <section id="product" class="module">
                <div class="module-header">
                    <h2><i class="fas fa-box-open"></i> Product Maker Packaging Output</h2>
                    <p>Package your digital product for sale</p>
                </div>
                
                <form id="productForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="productName">Product Name</label>
                            <input type="text" id="productName" class="form-control" placeholder="Enter product name">
                        </div>
                        <div class="form-group">
                            <label for="productPrice">Price ($)</label>
                            <input type="number" id="productPrice" class="form-control" placeholder="0.00" step="0.01">
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="productDescription">Product Description</label>
                        <textarea id="productDescription" class="form-control" placeholder="Describe your product in detail"></textarea>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="productFeatures">Key Features (one per line)</label>
                            <textarea id="productFeatures" class="form-control" placeholder="Feature 1&#10;Feature 2&#10;Feature 3"></textarea>
                        </div>
                        <div class="form-group">
                            <label for="deliveryFormat">Delivery Format</label>
                            <select id="deliveryFormat" class="form-control">
                                <option value="">Select format</option>
                                <option value="pdf">PDF</option>
                                <option value="video">Video Files</option>
                                <option value="access">Membership Access</option>
                                <option value="download">Downloadable Files</option>
                                <option value="saas">SaaS Platform</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="actions">
                        <button type="submit" class="btn">Generate Packaging</button>
                        <button type="button" id="clearProduct" class="btn btn-secondary">Clear Form</button>
                    </div>
                </form>
                
                <div class="output-section" id="productOutput" style="display: none;">
                    <h3>Product Packaging Output</h3>
                    <div class="output-content" id="productContent"></div>
                    <div class="actions">
                        <button type="button" id="exportProduct" class="btn btn-success"><i class="fas fa-download"></i> Export as Text</button>
                    </div>
                </div>
            </section>

            <!-- Content Planner Module -->
            <section id="content" class="module">
                <div class="module-header">
                    <h2><i class="fas fa-pen-fancy"></i> Blog/Course Content Planner</h2>
                    <p>Plan your content for blogs and courses</p>
                </div>
                
                <form id="contentForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="contentTitle">Content Title</label>
                            <input type="text" id="contentTitle" class="form-control" placeholder="Enter content title">
                        </div>
                        <div class="form-group">
                            <label for="contentType">Content Type</label>
                            <select id="contentType" class="form-control">
                                <option value="">Select type</option>
                                <option value="blog">Blog Post</option>
                                <option value="course">Course Module</option>
                                <option value="email">Email Newsletter</option>
                                <option value="social">Social Media Post</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="contentTopic">Topic/Subject</label>
                            <input type="text" id="contentTopic" class="form-control" placeholder="Main topic or subject">
                        </div>
                        <div class="form-group">
                            <label for="contentDueDate">Due Date</label>
                            <input type="date" id="contentDueDate" class="form-control">
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="contentOutline">Content Outline</label>
                        <textarea id="contentOutline" class="form-control" placeholder="Outline your content structure"></textarea>
                    </div>
                    
                    <div class="actions">
                        <button type="submit" class="btn">Add to Content Plan</button>
                        <button type="button" id="clearContent" class="btn btn-secondary">Clear Form</button>
                    </div>
                </form>
                
                <div class="output-section">
                    <h3>Content Plan</h3>
                    <table id="contentPlanTable">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Topic</th>
                                <th>Due Date</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="contentPlanList">
                            <!-- Content items will be added here -->
                        </tbody>
                    </table>
