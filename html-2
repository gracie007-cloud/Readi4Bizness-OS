           Readi4Bizness OS — CANVAS OUTPUT
        ═══════════════════════════════════════════
        Generated: ${new Date().toLocaleString()}
        ─────────────────────────────────────────
        🧩 BLUEPRINT
        Name:      ${b.businessName || '—'}
        Vision:    ${b.vision || '—'}
        Mission:   ${b.mission || '—'}
        Audience:  ${b.targetAudience || '—'}
        Value:     ${b.valueProposition || '—'}
        Revenue:   ${b.revenueModel || '—'}
        ─────────────────────────────────────────
        🔬 RESEARCH
        Idea:      ${r.productIdea || '—'}
        Score:     ${r.score !== null ? r.score + '/100' : '—'}
        ─────────────────────────────────────────
        📦 PRODUCT
        Name:      ${p.productName || '—'}
        Type:      ${p.productType || '—'}
        Target:    ${p.targetUser || '—'}
        Format:    ${p.packaging || '—'}
        ─────────────────────────────────────────
        ✍️ CONTENT
        Topic:     ${ct.topic || '—'}
        Type:      ${ct.contentType || '—'}
        Audience:  ${ct.audience || '—'}
        ─────────────────────────────────────────
        📢 PROMOTION
        Product:   ${pr.product || '—'}
        Channel:   ${pr.channel || '—'}
        Budget:    ${pr.budget || '—'}
        ─────────────────────────────────────────
        End of Report
        ═══════════════════════════════════════════
            `.trim();

            return `
            <h1>📄 Canvas Export</h1>
            <p class="page-desc">Composite document with all your business data. Export as text.</p>
            <div class="card">
              <div class="card-header">
                <h2><i class="fas fa-file-alt" style="color:var(--accent);margin-right:8px;"></i> Master Canvas</h2>
                <i class="fas fa-print"></i>
              </div>
              <div class="canvas-tools">
                <button class="btn btn-sm" id="cv_refresh"><i class="fas fa-sync-alt"></i> Refresh from State</button>
                <button class="btn btn-sm btn-outline" id="cv_export"><i class="fas fa-download"></i> Export .txt</button>
                <button class="btn btn-sm btn-outline" id="cv_copy"><i class="fas fa-copy"></i> Copy to Clipboard</button>
                <button class="btn btn-sm btn-danger" id="cv_clear"><i class="fas fa-trash"></i> Clear Canvas</button>
              </div>
              <div class="output-box" id="cv_output" style="max-height:500px;font-size:0.85rem;">${c.content || composite}</div>
              <p style="font-size:0.8rem;color:var(--text2);margin-top:10px;">
                <i class="fas fa-info-circle"></i> The canvas auto-populates from your Blueprint, Research, Product, Content, and Promotion modules.
              </p>
            </div>
          `;
        }

        function buildCompositeCanvas() {
            const b = state.blueprint;
            const r = state.research;
            const p = state.productmaker;
            const ct = state.content;
            const pr = state.promotion;

            return `
        ═══════════════════════════════════════════
           Readi4Bizness OS — CANVAS OUTPUT
        ═══════════════════════════════════════════
        Generated: ${new Date().toLocaleString()}
        ─────────────────────────────────────────
        🧩 BLUEPRINT
        Name:      ${b.businessName || '—'}
        Vision:    ${b.vision || '—'}
        Mission:   ${b.mission || '—'}
        Audience:  ${b.targetAudience || '—'}
        Value:     ${b.valueProposition || '—'}
        Revenue:   ${b.revenueModel || '—'}
        ─────────────────────────────────────────
        🔬 RESEARCH
        Idea:      ${r.productIdea || '—'}
        Score:     ${r.score !== null ? r.score + '/100' : '—'}
        ─────────────────────────────────────────
        📦 PRODUCT
        Name:      ${p.productName || '—'}
        Type:      ${p.productType || '—'}
        Target:    ${p.targetUser || '—'}
        Format:    ${p.packaging || '—'}
        ─────────────────────────────────────────
        ✍️ CONTENT
        Topic:     ${ct.topic || '—'}
        Type:      ${ct.contentType || '—'}
        Audience:  ${ct.audience || '—'}
        ─────────────────────────────────────────
        📢 PROMOTION
        Product:   ${pr.product || '—'}
        Channel:   ${pr.channel || '—'}
        Budget:    ${pr.budget || '—'}
        ─────────────────────────────────────────
        End of Report
        ═══════════════════════════════════════════
            `.trim();
        }

        function bindCanvas() {
            const refreshBtn = document.getElementById('cv_refresh');
            const exportBtn = document.getElementById('cv_export');
            const copyBtn = document.getElementById('cv_copy');
            const clearBtn = document.getElementById('cv_clear');
            const output = document.getElementById('cv_output');

            if (refreshBtn) {
                refreshBtn.addEventListener('click', () => {
                    const composite = buildCompositeCanvas();
                    state.canvas.content = composite;
                    saveState();
                    renderAll();
                });
            }

            if (exportBtn) {
                exportBtn.addEventListener('click', () => {
                    const text = output ? output.textContent : state.canvas.content || buildCompositeCanvas();
                    const blob = new Blob([text], { type: 'text/plain' });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `Readi4Bizness_Canvas_${new Date().toISOString().slice(0,10)}.txt`;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                });
            }

            if (copyBtn) {
                copyBtn.addEventListener('click', () => {
                    const text = output ? output.textContent : state.canvas.content || buildCompositeCanvas();
                    navigator.clipboard.writeText(text).then(() => {
                        const orig = copyBtn.innerHTML;
                        copyBtn.innerHTML = '✅ Copied!';
                        setTimeout(() => { copyBtn.innerHTML = orig; }, 1500);
                    }).catch(() => {
                        alert('Could not copy. Please select and copy manually.');
                    });
                });
            }

            if (clearBtn) {
                clearBtn.addEventListener('click', () => {
                    state.canvas.content = '';
                    saveState();
                    renderAll();
                });
            }

            // If canvas content is empty, populate it on first view
            if (state.canvas.content === '') {
                state.canvas.content = buildCompositeCanvas();
                saveState();
                // We need to re-render the canvas page specifically
                // renderAll will handle it since we call it after bind
            }
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  INIT
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        // On load, if not logged in, show modal
        // We'll start with modal visible
        loginOverlay.classList.remove('hidden');
        app.classList.remove('active');

        // If already logged in somehow (e.g. session) – but we start clean.

        // Pre-populate canvas content if empty
        if (state.canvas.content === '') {
            state.canvas.content = buildCompositeCanvas();
            saveState();
        }

        console.log('⚡ Readi4Bizness OS loaded. State:', state);
    </script>
</body>
</html>
