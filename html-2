<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Readi4Bizness OS</title>
    <!-- Font Awesome -->
    <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />
    <!-- Google Fonts: Inter -->
    <link
    href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap"
    rel="stylesheet"
    />
    <style>
        /* ─── RESET & BASE ─── */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg: #f4f6fb;
            --surface: #ffffff;
            --surface2: #eef1f8;
            --text: #1a1d29;
            --text2: #5a5f73;
            --accent: #4f6ef7;
            --accent2: #3a56d4;
            --accent-light: #e8ecff;
            --border: #d9dfeb;
            --shadow: 0 8px 30px rgba(0, 0, 0, 0.05);
            --radius: 14px;
            --radius-sm: 8px;
            --transition: 0.25s ease;
            --green: #22c55e;
            --green-bg: #e6f9ed;
            --orange: #f59e0b;
            --orange-bg: #fef3e0;
            --red: #ef4444;
            --red-bg: #fde8e8;
            --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ─── LOGIN MODAL ─── */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.45);
            backdrop-filter: blur(6px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            transition: opacity 0.35s ease, visibility 0.35s ease;
        }
        .modal-overlay.hidden {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }

        .modal-card {
            background: var(--surface);
            padding: 44px 40px 38px;
            border-radius: var(--radius);
            width: 100%;
            max-width: 420px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2);
            text-align: center;
            transition: transform 0.35s ease;
        }
        .modal-overlay.hidden .modal-card {
            transform: scale(0.95);
        }

        .modal-card .logo {
            font-size: 2.2rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: var(--accent);
            margin-bottom: 4px;
        }
        .modal-card .logo-sub {
            font-size: 0.85rem;
            color: var(--text2);
            margin-bottom: 24px;
            letter-spacing: 0.3px;
        }
        .modal-card h2 {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 6px;
        }
        .modal-card p {
            color: var(--text2);
            font-size: 0.95rem;
            margin-bottom: 24px;
        }

        .login-form {
            display: flex;
            flex-direction: column;
            gap: 14px;
            text-align: left;
        }
        .login-form label {
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text2);
        }
        .login-form input {
            padding: 12px 16px;
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 0.95rem;
            font-family: var(--font);
            background: var(--bg);
            transition: border 0.2s;
            outline: none;
        }
        .login-form input:focus {
            border-color: var(--accent);
            background: #fff;
        }
        .login-form .btn {
            margin-top: 6px;
            padding: 14px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 1rem;
            font-weight: 600;
            font-family: var(--font);
            cursor: pointer;
            transition: background 0.2s;
        }
        .login-form .btn:hover {
            background: var(--accent2);
        }
        .login-error {
            color: var(--red);
            font-size: 0.85rem;
            text-align: center;
            min-height: 24px;
        }

        /* ─── APP LAYOUT ─── */
        .app {
            display: none;
            width: 100%;
            max-width: 1440px;
            min-height: 100vh;
            background: var(--bg);
        }
        .app.active {
            display: flex;
        }

        /* ─── SIDEBAR ─── */
        .sidebar {
            width: 250px;
            background: var(--surface);
            border-right: 1px solid var(--border);
            padding: 28px 18px;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            height: 100vh;
            position: sticky;
            top: 0;
            overflow-y: auto;
        }
        .sidebar .logo {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: -0.3px;
            color: var(--accent);
            margin-bottom: 4px;
            padding-left: 8px;
        }
        .sidebar .logo-sub {
            font-size: 0.75rem;
            color: var(--text2);
            margin-bottom: 28px;
            padding-left: 8px;
            letter-spacing: 0.2px;
        }
        .sidebar nav {
            display: flex;
            flex-direction: column;
            gap: 4px;
            flex: 1;
        }
        .sidebar nav a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: var(--radius-sm);
            text-decoration: none;
            color: var(--text2);
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s;
            cursor: pointer;
        }
        .sidebar nav a i {
            width: 20px;
            text-align: center;
            font-size: 1rem;
        }
        .sidebar nav a:hover {
            background: var(--accent-light);
            color: var(--accent);
        }
        .sidebar nav a.active {
            background: var(--accent);
            color: #fff;
        }
        .sidebar .logout-wrap {
            margin-top: 20px;
            padding-top: 18px;
            border-top: 1px solid var(--border);
            display: flex;
            gap: 10px;
        }
        .sidebar .logout-wrap button {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 0.85rem;
            font-weight: 500;
            font-family: var(--font);
            cursor: pointer;
            background: var(--surface2);
            color: var(--text2);
            transition: background 0.2s;
        }
        .sidebar .logout-wrap button:hover {
            background: var(--red-bg);
            color: var(--red);
        }

        /* ─── MAIN CONTENT ─── */
        .main {
            flex: 1;
            padding: 36px 40px 40px 40px;
            overflow-y: auto;
            max-height: 100vh;
        }

        .page {
            display: none;
            animation: fadeUp 0.35s ease;
        }
        .page.active {
            display: block;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page h1 {
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: -0.3px;
            margin-bottom: 4px;
        }
        .page .page-desc {
            color: var(--text2);
            font-size: 0.95rem;
            margin-bottom: 28px;
        }

        /* ─── CARDS ─── */
        .card {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 24px 28px;
            box-shadow: var(--shadow);
            margin-bottom: 20px;
            transition: box-shadow 0.2s;
        }
        .card:hover {
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.07);
        }
        .card .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }
        .card .card-header h2 {
            font-size: 1.15rem;
            font-weight: 600;
        }
        .card .card-header i {
            color: var(--accent);
            font-size: 1.3rem;
        }

        /* status badges */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 14px;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 500;
        }
        .status-badge.green {
            background: var(--green-bg);
            color: var(--green);
        }
        .status-badge.orange {
            background: var(--orange-bg);
            color: var(--orange);
        }
        .status-badge.red {
            background: var(--red-bg);
            color: var(--red);
        }
        .status-badge i {
            font-size: 0.65rem;
        }

        /* grids */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .grid-3 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 20px;
        }

        /* forms & inputs inside cards */
        .card label {
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text2);
            display: block;
            margin-bottom: 4px;
        }
        .card input,
        .card textarea,
        .card select {
            width: 100%;
            padding: 10px 14px;
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 0.9rem;
            font-family: var(--font);
            background: var(--bg);
            transition: border 0.2s;
            outline: none;
            margin-bottom: 12px;
        }
        .card input:focus,
        .card textarea:focus,
        .card select:focus {
            border-color: var(--accent);
            background: #fff;
        }
        .card textarea {
            resize: vertical;
            min-height: 70px;
        }
        .card .btn {
            padding: 10px 22px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 0.9rem;
            font-weight: 600;
            font-family: var(--font);
            cursor: pointer;
            transition: background 0.2s;
        }
        .card .btn:hover {
            background: var(--accent2);
        }
        .card .btn-outline {
            background: transparent;
            color: var(--accent);
            border: 1.5px solid var(--accent);
        }
        .card .btn-outline:hover {
            background: var(--accent-light);
        }
        .card .btn-sm {
            padding: 6px 16px;
            font-size: 0.8rem;
        }
        .card .btn-danger {
            background: var(--red);
        }
        .card .btn-danger:hover {
            background: #dc2626;
        }

        .output-box {
            background: var(--surface2);
            border-radius: var(--radius-sm);
            padding: 16px 18px;
            font-size: 0.9rem;
            white-space: pre-wrap;
            max-height: 260px;
            overflow-y: auto;
            margin-top: 10px;
            border: 1px solid var(--border);
            font-family: 'Courier New', monospace;
            line-height: 1.5;
        }

        .stat-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.9rem;
        }
        .stat-row:last-child {
            border-bottom: none;
        }
        .stat-row .stat-label {
            color: var(--text2);
        }
        .stat-row .stat-value {
            font-weight: 600;
        }

        .flex-between {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }
        .badge-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 8px;
        }
        .badge-list .badge {
            background: var(--accent-light);
            color: var(--accent);
            padding: 4px 14px;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .canvas-tools {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        /* responsive */
        @media (max-width: 900px) {
            .grid-2,
            .grid-3 {
                grid-template-columns: 1fr;
            }
            .sidebar {
                width: 200px;
                padding: 20px 12px;
            }
            .main {
                padding: 24px 20px;
            }
        }
        @media (max-width: 650px) {
            .app.active {
                flex-direction: column;
            }
            .sidebar {
                width: 100%;
                height: auto;
                position: static;
                flex-direction: row;
                flex-wrap: wrap;
                padding: 12px 16px;
                border-right: none;
                border-bottom: 1px solid var(--border);
            }
            .sidebar .logo,
            .sidebar .logo-sub {
                display: none;
            }
            .sidebar nav {
                flex-direction: row;
                flex-wrap: wrap;
                gap: 2px;
            }
            .sidebar nav a {
                font-size: 0.75rem;
                padding: 8px 10px;
                gap: 6px;
            }
            .sidebar .logout-wrap {
                margin-top: 0;
                padding-top: 0;
                border-top: none;
                margin-left: auto;
            }
            .main {
                max-height: none;
                padding: 20px 16px;
            }
            .modal-card {
                padding: 28px 20px;
            }
        }
    </style>
</head>
<body>
    <!-- ─── LOGIN MODAL ─── -->
    <div class="modal-overlay" id="loginOverlay">
        <div class="modal-card">
            <div class="logo">⚡ R4B</div>
            <div class="logo-sub">Readi4Bizness OS</div>
            <h2>Welcome back</h2>
            <p>Sign in to your business operating system</p>
            <form class="login-form" id="loginForm" autocomplete="off">
                <label for="email">Email</label>
                <input
                type="email"
                id="email"
                value="demo@readi4bizness.com"
                placeholder="demo@readi4bizness.com"
                />
                <label for="password">Password</label>
                <input
                type="password"
                id="password"
                value="readi-demo-2026"
                placeholder="••••••••••"
                />
                <div class="login-error" id="loginError"></div>
                <button type="submit" class="btn">Sign in</button>
            </form>
        </div>
    </div>

    <!-- ─── APP ─── -->
    <div class="app" id="app">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="logo">⚡ R4B</div>
            <div class="logo-sub">Readi4Bizness OS</div>
            <nav id="nav">
                <a class="active" data-page="dashboard"><i class="fas fa-chart-pie"></i> Dashboard</a>
                <a data-page="blueprint"><i class="fas fa-cubes"></i> Blueprint</a>
                <a data-page="research"><i class="fas fa-microscope"></i> Research</a>
                <a data-page="productmaker"><i class="fas fa-box-open"></i> Product Maker</a>
                <a data-page="content"><i class="fas fa-pen-fancy"></i> Content Planner</a>
                <a data-page="promotion"><i class="fas fa-bullhorn"></i> Promotion</a>
                <a data-page="canvas"><i class="fas fa-file-alt"></i> Canvas Export</a>
            </nav>
            <div class="logout-wrap">
                <button id="logoutBtn"><i class="fas fa-sign-out-alt"></i> Logout</button>
            </div>
        </aside>

        <!-- Main -->
        <main class="main" id="mainContent">
            <!-- Each page is a div.page, toggled via JS -->
            <!-- Will be rendered by JavaScript -->
        </main>
    </div>

    <script>
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  STATE (localStorage)
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        const STORAGE_KEY = 'readi4bizness_os_state';

        function defaultState() {
            return {
                // Dashboard stats (some computed)
                dashboard: {
                    projectsActive: 3,
                    tasksPending: 12,
                    revenue: '$4,280',
                    health: 'good', // 'good' | 'warning' | 'critical'
                    lastLogin: new Date().toLocaleDateString(),
                },
                // Blueprint
                blueprint: {
                    businessName: '',
                    vision: '',
                    mission: '',
                    targetAudience: '',
                    valueProposition: '',
                    revenueModel: '',
                    output: '',
                },
                // Research
                research: {
                    productIdea: '',
                    marketSize: 'small',
                    competition: 'medium',
                    demand: 'medium',
                    readiness: 'medium',
                    score: null,
                    result: '',
                },
                // Product Maker
                productmaker: {
                    productName: '',
                    productType: 'ebook',
                    features: '',
                    targetUser: '',
                    packaging: '',
                    output: '',
                },
                // Content Planner
                content: {
                    topic: '',
                    contentType: 'blog',
                    audience: '',
                    goals: '',
                    outline: '',
                    generated: '',
                },
                // Promotion
                promotion: {
                    product: '',
                    channel: 'facebook',
                    budget: '100',
                    audience: '',
                    message: '',
                    plan: '',
                },
                // Canvas
                canvas: {
                    content: '',
                },
            };
        }

        function loadState() {
            try {
                const raw = localStorage.getItem(STORAGE_KEY);
                if (raw) {
                    const parsed = JSON.parse(raw);
                    // Merge with defaults to handle new fields
                    const def = defaultState();
                    for (const key of Object.keys(def)) {
                        if (!parsed[key]) parsed[key] = def[key];
                        else {
                            for (const sub of Object.keys(def[key])) {
                                if (parsed[key][sub] === undefined) parsed[key][sub] = def[key][sub];
                            }
                        }
                    }
                    return parsed;
                }
            } catch (e) { /* ignore */ }
            return defaultState();
        }

        function saveState() {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
        }

        let state = loadState();

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  LOGIN
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        const loginOverlay = document.getElementById('loginOverlay');
        const loginForm = document.getElementById('loginForm');
        const loginError = document.getElementById('loginError');
        const app = document.getElementById('app');

        function handleLogin(e) {
            e.preventDefault();
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value.trim();
            if (
                email === 'demo@readi4bizness.com' &&
                password === 'readi-demo-2026'
            ) {
                loginOverlay.classList.add('hidden');
                app.classList.add('active');
                loginError.textContent = '';
                renderAll();
            } else {
                loginError.textContent = '❌ Invalid credentials. Please use the demo account.';
            }
        }

        loginForm.addEventListener('submit', handleLogin);

        document.getElementById('logoutBtn').addEventListener('click', () => {
            app.classList.remove('active');
            loginOverlay.classList.remove('hidden');
            document.getElementById('email').value = 'demo@readi4bizness.com';
            document.getElementById('password').value = 'readi-demo-2026';
            loginError.textContent = '';
            // reset state
            state = defaultState();
            saveState();
        });

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  NAVIGATION
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        let currentPage = 'dashboard';

        function navigateTo(pageId) {
            currentPage = pageId;
            document.querySelectorAll('#nav a').forEach(el => el.classList.remove('active'));
            const navLink = document.querySelector(`#nav a[data-page="${pageId}"]`);
            if (navLink) navLink.classList.add('active');
            renderAll();
        }

        document.querySelectorAll('#nav a').forEach(el => {
            el.addEventListener('click', (e) => {
                e.preventDefault();
                navigateTo(el.dataset.page);
            });
        });

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  RENDER ENGINE
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        const mainEl = document.getElementById('mainContent');

        function renderAll() {
            // Build all pages, show only current
            const pages = {
                dashboard: renderDashboard(),
                blueprint: renderBlueprint(),
                research: renderResearch(),
                productmaker: renderProductMaker(),
                content: renderContent(),
                promotion: renderPromotion(),
                canvas: renderCanvas(),
            };

            let html = '';
            for (const [key, content] of Object.entries(pages)) {
                const active = key === currentPage ? 'active' : '';
                html += `<div class="page ${active}" data-page="${key}">${content}</div>`;
            }
            mainEl.innerHTML = html;

            // Re-bind events per page
            bindDashboard();
            bindBlueprint();
            bindResearch();
            bindProductMaker();
            bindContent();
            bindPromotion();
            bindCanvas();

            // Save state after any render (values are read from state)
            saveState();
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  DASHBOARD
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        function renderDashboard() {
            const d = state.dashboard;
            const healthIcon = d.health === 'good' ? '✅' : d.health === 'warning' ? '⚠️' : '🔴';
            const healthLabel = d.health === 'good' ? 'All Systems Go' : d.health === 'warning' ? 'Needs Attention' :
            'Critical';
            const healthClass = d.health === 'good' ? 'green' : d.health === 'warning' ? 'orange' : 'red';

            return `
            <h1>📊 Dashboard</h1>
            <p class="page-desc">Real-time operating status of your digital product business.</p>

            <div class="grid-2">
              <div class="card">
                <div class="card-header">
