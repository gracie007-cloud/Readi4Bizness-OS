                    r.competition = document.getElementById('rs_competition').value;
                    r.demand = document.getElementById('rs_demand').value;
                    r.readiness = document.getElementById('rs_readiness').value;

                    // Simple scoring
                    const marketScore = { small: 30, medium: 60, large: 90 } [r.marketSize] || 50;
                    const compScore = { low: 80, medium: 50, high: 20 } [r.competition] || 50;
                    const demandScore = { low: 25, medium: 55, high: 85 } [r.demand] || 50;
                    const readinessScore = { low: 30, medium: 60, high: 95 } [r.readiness] || 50;
                    const total = Math.round((marketScore + compScore + demandScore + readinessScore) / 4);
                    r.score = total;

                    let verdict = '';
                    if (total >= 75) verdict = '✅ Strong viability – proceed with confidence!';
                    else if (total >= 50) verdict = '⚠️ Moderate viability – refine your approach.';
