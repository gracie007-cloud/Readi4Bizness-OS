        function updateContentPlansList() {
            const list = document.getElementById('content-plans-list');
            if (!state.data.content || state.data.content.length === 0) {
                list.innerHTML = '<p>No content plans saved yet. Create one above.</p>';
                return;
            }
            
            let html = '<ul style="list-style-type: none; padding-left: 0;">';
            state.data.content.slice(-5).reverse().forEach((plan, index) => {
                const date = new Date(plan.timestamp).toLocaleDateString();
                html += `
                    <li style="padding: 1rem; border-bottom: 1px solid var(--light-gray); margin-bottom: 0.5rem; background-color: ${index % 2 === 0 ? 'var(--light-gray)' : 'white'}; border-radius: 4px;">
