                adCopy = `
                    <h4>Google Ads Copy</h4>
                    <p><strong>Headline 1:</strong> [Problem] Solution</p>
                    <p><strong>Headline 2:</strong> Get Results Fast</p>
                    <p><strong>Headline 3:</strong> Expert Approved Method</p>
                    <p><strong>Description:</strong> ${message} Proven system that works. Easy to implement. See real results in days.</p>
                    <p><strong>Display Path:</strong> example.com/solution</p>
                `;
            } else if (platform === 'affiliate') {
                adCopy = `
                    <h4>Affiliate Promotion Email</h4>
                    <p><strong>Subject:</strong> Exclusive offer for your audience: [Product Name]</p>
                    <p><strong>Body:</strong> Hi [Affiliate Name],</p>
                    <p>I wanted to share an exclusive opportunity with you and your audience. ${message}</p>
                    <p>Your audience will love this because [reason]. You'll earn [commission] on every sale.</p>
                    <p>Use this special link: [affiliate-link]</p>
                    <p>Let me know if you have any questions!</p>
                    <p>Best,<br>[Your Name]</p>
                `;
            }
            
            document.getElementById('ad-copy-output').innerHTML = adCopy;
            addActivity('Ad copy generated', `${platform} advertising content created`, 'bullhorn', 'accent');
            alert(`Ad copy generated for ${platform}!`);
        }
        
        // Canvas functions
        function refreshCanvas() {
            const canvas = document.getElementById('canvas-output');
            
            let content = '<h3>Readi4Bizness OS - Business Canvas</h3>';
            content += `<p><em>Generated on ${new Date().toLocaleString()}</em></p>`;
            content += `<p><strong>User:</strong> ${state.loggedIn ? DEMO_EMAIL : 'Not logged in'}</p>`;
            content += '<hr>';
            
            // Dashboard
            if (state.data.dashboard && Object.keys(state.data.dashboard).length > 0) {
                content += '<h4>Operating Status</h4>';
                content += `<p><strong>Business Health:</strong> ${state.data.dashboard.businessHealth || 'Not set'}</p>`;
                content += `<p><strong>Cash Flow:</strong> ${state.data.dashboard.cashFlow || 'Not set'}</p>`;
                content += `<p><strong>Monthly Goals:</strong> ${state.data.dashboard.monthlyGoals || 0}%</p>`;
            }
            
            // Blueprint
            if (state.data.blueprint && state.data.blueprint.businessName) {
                content += '<h4>Business Blueprint</h4>';
                content += `<p><strong>Business Name:</strong> ${state.data.blueprint.businessName}</p>`;
                content += `<p><strong>Niche:</strong> ${state.data.blueprint.niche}</p>`;
                content += `<p><strong>Value Proposition:</strong> ${state.data.blueprint.valueProposition}</p>`;
            }
            
            // Product
            if (state.data.product && state.data.product.title) {
                content += '<h4>Digital Product</h4>';
                content += `<p><strong>Product:</strong> ${state.data.product.title}</p>`;
                content += `<p><strong>Type:</strong> ${state.data.product.type}</p>`;
                content += `<p><strong>Price:</strong> $${parseFloat(state.data.product.price || 0).toFixed(2)}</p>`;
            }
            
            // Content Plans
            if (state.data.content && state.data.content.length > 0) {
                content += '<h4>Content Plans</h4>';
                content += `<p><strong>Total Plans:</strong> ${state.data.content.length}</p>`;
                state.data.content.slice(-3).forEach(plan => {
                    content += `<p>• ${plan.title} (${plan.type})</p>`;
                });
            }
            
            // Campaigns
            if (state.data.ads && state.data.ads.length > 0) {
                content += '<h4>Promotion Campaigns</h4>';
                content += `<p><strong>Total Campaigns:</strong> ${state.data.ads.length}</p>`;
                state.data.ads.slice(-2).forEach(campaign => {
                    content += `<p>• ${campaign.name} (${campaign.platform}) - $${campaign.budget}</p>`;
                });
            }
            
            // Activity
            if (state.data.activity && state.data.activity.length > 0) {
                content += '<h4>Recent Activity</h4>';
                state.data.activity.slice(-3).forEach(activity => {
                    const time = new Date(activity.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                    content += `<p>• ${time}: ${activity.action} - ${activity.details}</p>`;
                });
            }
            
            content += '<hr>';
            content += '<p><strong>Summary:</strong> Your business system contains data across ' + 
                [state.data.dashboard, state.data.blueprint, state.data.research, state.data.product, state.data.content, state.data.ads]
                .filter(item => item && Object.keys(item).length > 0).length + ' different areas.</p>';
            
            canvas.innerHTML = content;
            addActivity('Canvas refreshed', 'Business data compiled for export', 'sync-alt', 'primary');
        }
        
        function exportText() {
            refreshCanvas();
            const canvasContent = document.getElementById('canvas-output').textContent;
            
            const blob = new Blob([canvasContent], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `readi4bizness-canvas-${new Date().toISOString().slice(0, 10)}.txt`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            
            addActivity('Canvas exported', 'Business data downloaded as text file', 'download', 'success');
            alert('Canvas exported as text file!');
        }
        
        function printCanvas() {
            refreshCanvas();
            window.print();
            addActivity('Canvas printed', 'Business data sent to printer', 'print', 'secondary');
        }
        
        function clearAllData() {
            if (confirm('Are you sure you want to clear ALL data? This cannot be undone.')) {
                // Clear all localStorage keys
                for (const key in state.data) {
                    localStorage.removeItem(`readi4bizness_${key}`);
                    state.data[key] = key === 'activity' ? [] : {};
                }
                
                // Clear form fields
                document.querySelectorAll('input, textarea, select').forEach(element => {
                    if (element.type !== 'range') {
                        element.value = '';
                    }
                });
                
                // Reset dashboard slider
                document.getElementById('monthly-goals').value = 0;
                document.getElementById('goals-percentage').textContent = '0%';
                
                // Update UI
                updateDashboardStats();
                updateActivityList();
                updateContentPlansList();
                
                // Refresh canvas
                refreshCanvas();
                
                addActivity('All data cleared', 'Local storage reset to default', 'trash-alt', 'danger');
                alert('All data has been cleared!');
            }
        }
        
        // Initialize the app when page loads
        document.addEventListener('DOMContentLoaded', initApp);
    </script>
</body>
</html>
