    <script>
        // App State
        const state = {
            loggedIn: false,
            currentSection: 'dashboard',
            data: {
                dashboard: {},
                blueprint: {},
                research: {},
                product: {},
                content: [],
                ads: [],
                activity: []
            }
        };
        
        // DOM Elements
        const loginModal = document.getElementById('login-modal');
        const showLoginBtn = document.getElementById('show-login-btn');
        const logoutBtn = document.getElementById('logout-btn');
        const loginSubmitBtn = document.getElementById('login-submit');
        const loginEmail = document.getElementById('login-email');
        const loginPassword = document.getElementById('login-password');
        const loginError = document.getElementById('login-error');
        const userEmailSpan = document.getElementById('user-email');
        const navItems = document.querySelectorAll('.nav-item');
        const sectionContents = document.querySelectorAll('.section-content');
        
        // Demo credentials
        const DEMO_EMAIL = 'demo@readi4bizness.com';
        const DEMO_PASSWORD = 'readi-demo-2026';
        
        // Initialize the app
        function initApp() {
            // Load saved data from localStorage
            loadState();
            
            // Check if user is logged in
            const savedLogin = localStorage.getItem('readi4bizness_loggedIn');
            if (savedLogin === 'true') {
                state.loggedIn = true;
                updateUIForLogin();
            } else {
                loginModal.classList.add('active');
            }
            
            // Setup event listeners
            setupEventListeners();
            
            // Initialize dashboard stats
            updateDashboardStats();
        }
        
        // Load state from localStorage
        function loadState() {
            for (const key in state.data) {
                const saved = localStorage.getItem(`readi4bizness_${key}`);
                if (saved) {
                    try {
                        state.data[key] = JSON.parse(saved);
                    } catch (e) {
                        console.error(`Error parsing ${key} from localStorage:`, e);
                    }
                }
            }
            
            // Load dashboard values if they exist
            if (state.data.dashboard.businessHealth) {
                document.getElementById('business-health').value = state.data.dashboard.businessHealth;
            }
            if (state.data.dashboard.cashFlow) {
                document.getElementById('cash-flow').value = state.data.dashboard.cashFlow;
            }
            if (state.data.dashboard.monthlyGoals) {
                document.getElementById('monthly-goals').value = state.data.dashboard.monthlyGoals;
                document.getElementById('goals-percentage').textContent = `${state.data.dashboard.monthlyGoals}%`;
            }
            
            // Update activity list
            updateActivityList();
        }
        
        // Save state to localStorage
        function saveState() {
            for (const key in state.data) {
                localStorage.setItem(`readi4bizness_${key}`, JSON.stringify(state.data[key]));
            }
        }
        
        // Update dashboard statistics
        function updateDashboardStats() {
            // Revenue - sum of product prices
            let revenue = 0;
            if (state.data.product && state.data.product.price) {
                revenue = parseFloat(state.data.product.price) || 0;
            }
            document.getElementById('revenue-stat').textContent = `$${revenue.toFixed(2)}`;
            
            // Customers - random for demo
            const customers = Math.floor(Math.random() * 100) + 20;
            document.getElementById('customers-stat').textContent = customers;
            
            // Products - count from content plans
            const products = state.data.content ? state.data.content.length : 0;
            document.getElementById('products-stat').textContent = products;
            
            // Tasks - from activity
            const totalTasks = 10;
            const completedTasks = Math.min(state.data.activity ? state.data.activity.length : 0, totalTasks);
            document.getElementById('tasks-stat').textContent = `${completedTasks}/${totalTasks}`;
        }
        
        // Update activity list
        function updateActivityList() {
            const activityList = document.getElementById('activity-list');
            if (!state.data.activity || state.data.activity.length === 0) {
                activityList.innerHTML = '<p>No recent activity. Start using the tools to see activity here.</p>';
                return;
            }
            
            let html = '<ul style="list-style-type: none; padding-left: 0;">';
            state.data.activity.slice(-5).reverse().forEach(activity => {
                const time = new Date(activity.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                html += `
                    <li style="padding: 0.5rem 0; border-bottom: 1px solid var(--light-gray);">
                        <div style="display: flex; align-items: center; gap: ANIME:
   10px;">
                            <i class="fas fa-${activity.icon}" style="color: var(--${activity.color});"></i>
                            <div>
                                <strong>${activity.action}</strong>
                                <div style="font-size: 0.9rem; color: var(--gray);">
                                    ${time} - ${activity.details}
                                </div>
                            </div>
                        </div>
                    </li>
                `;
            });
            html += '</ul>';
            activityList.innerHTML = html;
        }
        
        // Add activity
        function addActivity(action, details, icon = 'check-circle', color = 'primary') {
            if (!state.data.activity) state.data.activity = [];
            
            state.data.activity.push({
                timestamp: new Date().toISOString(),
                action,
                details,
                icon,
                color
            });
            
            // Keep only last 20 activities
            if (state.data.activity.length > 20) {
                state.data.activity = state.data.activity.slice(-20);
            }
            
            localStorage.setItem('readi4bizness_activity', JSON.stringify(state.data.activity));
            updateActivityList();
            updateDashboardStats();
        }
        
        // Setup event listeners
        function setupEventListeners() {
            // Navigation
            navItems.forEach(item => {
                item.addEventListener('click', () => {
                    const section = item.dataset.section;
                    switchSection(section);
                });
            });
            
            // Login/Logout
            showLoginBtn.addEventListener('click', () => {
                loginModal.classList.add('active');
            });
            
            logoutBtn.addEventListener('click', () => {
                state.loggedIn = false;
                localStorage.setItem('readi4bizness_loggedIn', 'false');
                updateUIForLogin();
                loginModal.classList.add('active');
            });
            
            loginSubmitBtn.addEventListener('click', () => {
                const email = loginEmail.value.trim();
                const password = loginPassword.value.trim();
                
                if (email === DEMO_EMAIL && password === DEMO_PASSWORD) {
                    state.loggedIn = true;
                    localStorage.setItem('readi4bizness_loggedIn', 'true');
                    updateUIForLogin();
                    loginModal.classList.remove('active');
                    loginError.style.display = 'none';
                    addActivity('User logged in', 'Demo user accessed the system', 'sign-in-alt', 'success');
                } else {
                    loginError.style.display = 'block';
                }
            });
            
            // Dashboard
            document.getElementById('save-dashboard').addEventListener('click', saveDashboard);
            document.getElementById('monthly-goals').addEventListener('input', function() {
                document.getElementById('goals-percentage').textContent = `${this.value}%`;
            });
            
            // Blueprint
            document.getElementById('save-blueprint').addEventListener('click', saveBlueprint);
            document.getElementById('generate-blueprint').addEventListener('click', generateBlueprint);
            
            // Research
            document.getElementById('save-research').addEventListener('click', saveResearch);
            document.getElementById('scan-viability').addEventListener('click', scanViability);
            document.getElementById('problem-solved').addEventListener('input', function() {
                document.getElementById('problem-value').textContent = this.value;
            });
            
            // Product
            document.getElementById('save-product').addEventListener('click', saveProduct);
            document.getElementById('package-product').addEventListener('click', packageProduct);
            
            // Content
            document.getElementById('save-content').addEventListener('click', saveContent);
            document.getElementById('generate-outline').addEventListener('click', generateOutline);
            
            // Ads
            document.getElementById('save-campaign').addEventListener('click', saveCampaign);
            document.getElementById('generate-ad-copy').addEventListener('click', generateAdCopy);
            
            // Canvas
            document.getElementById('refresh-canvas').addEventListener('click', refreshCanvas);
            document.getElementById('export-text').addEventListener('click', exportText);
            document.getElementById('print-canvas').addEventListener('click', printCanvas);
            document.getElementById('clear-all-data').addEventListener('click', clearAllData);
        }
        
        // Switch between sections
        function switchSection(sectionId) {
            // Update navigation
            navItems.forEach(item => {
                if (item.dataset.section === sectionId) {
                    item.classList.add('active');
                } else {
                    item.classList.remove('active');
                }
            });
            
            // Update content visibility
            sectionContents.forEach(section => {
                if (section.id === `${sectionId}-section`) {
                    section.style.display = 'block';
                } else {
                    section.style.display = 'none';
                }
            });
            
            state.currentSection = sectionId;
            
            // Refresh canvas if on canvas section
            if (sectionId === 'canvas') {
                refreshCanvas();
            }
        }
        
        // Update UI for login state
        function updateUIForLogin() {
            if (state.loggedIn) {
                userEmailSpan.textContent = DEMO_EMAIL;
                showLoginBtn.style.display = 'none';
                logoutBtn.style.display = 'block';
            } else {
                userEmailSpan.textContent = 'Not logged in';
                showLoginBtn.style.display = 'block';
                logoutBtn.style.display = 'none';
            }
        }
        
        // Dashboard functions
        function saveDashboard() {
            state.data.dashboard = {
                businessHealth: document.getElementById('business-health').value,
                cashFlow: document.getElementById('cash-flow').value,
                monthlyGoals: document.getElementById('monthly-goals').value
            };
            
            localStorage.setItem('readi4bizness_dashboard', JSON.stringify(state.data.dashboard));
            addActivity('Dashboard updated', 'Operating status saved', 'tachometer-alt', 'primary');
            
            // Show status indicator
            let statusText, statusClass;
            switch(state.data.dashboard.businessHealth) {
                case 'good': statusText = 'Good'; statusClass = 'status-good'; break;
                case 'warning': statusText = 'Warning'; statusClass = 'status-warning'; break;
                case 'critical': statusText = 'Critical'; statusClass = 'status-critical'; break;
            }
            
            alert(`Dashboard saved with status: ${statusText}`);
        }
        
        // Blueprint functions
        function saveBlueprint() {
            state.data.blueprint = {
                businessName: document.getElementById('business-name').value,
                niche: document.getElementById('business-niche').value,
                audience: document.getElementById('target-audience').value,
                valueProposition: document.getElementById('value-proposition').value,
                revenueStreams: document.getElementById('revenue-streams').value
            };
            
            localStorage.setItem('readi4bizness_blueprint', JSON.stringify(state.data.blueprint));
            
            // Update preview
            const preview = document.getElementById('blueprint-preview');
            preview.innerHTML = `
                <h3>${state.data.blueprint.businessName || 'Your Business'}</h3>
                <p><strong>Niche:</strong> ${state.data.blueprint.niche || 'Not specified'}</p>
                <p><strong>Target Audience:</strong> ${state.data.blueprint.audience || 'Not specified'}</p>
                <p><strong>Value Proposition:</strong> ${state.data.blueprint.valueProposition || 'Not specified'}</p>
                <p><strong>Revenue Streams:</strong> ${state.data.blueprint.revenueStreams || 'Not specified'}</p>
            `;
            
            addActivity('Business blueprint saved', 'Business model updated', 'project-diagram', 'secondary');
            alert('Business blueprint saved successfully!');
        }
        
        function generateBlueprint() {
            document.getElementById('business-name').value = 'Digital Success Academy';
            document.getElementById('business-niche').value = 'Online Education & Digital Skills';
            document.getElementById('target-audience').value = 'Aspiring entrepreneurs, freelancers, and career changers looking to build digital businesses';
            document.getElementById('value-proposition').value = 'Step-by-step system for creating and selling digital products without technical expertise';
            document.getElementById('revenue-streams').value = 'Digital product sales, affiliate commissions, coaching programs, membership site';
            
            addActivity('Sample blueprint generated', 'Demo business model created', 'magic', 'accent');
            alert('Sample business blueprint generated! Click "Save Blueprint" to store it.');
        }
        
        // Research functions
        function saveResearch() {
            state.data.research = {
                productIdea: document.getElementById('product-idea').value,
                marketSize: document.getElementById('market-size').value,
                competition: document.getElementById('competition-level').value,
                problemSolved: document.getElementById('problem-solved').value,
                notes: document.getElementById('research-notes').value
            };
            
            localStorage.setItem('readi4bizness_research', JSON.stringify(state.data.research));
            addActivity('Product research saved', 'Viability scan data stored', 'search', 'primary');
            alert('Product research saved!');
        }
        
        function scanViability() {
            const idea = document.getElementById('product-idea').value;
            const market = document.getElementById('market-size').value;
            const competition = document.getElementById('competition-level').value;
            const problem = parseInt(document.getElementById('problem-solved').value);
            
            if (!idea) {
                alert('Please enter a product idea first');
                return;
            }
            
            // Calculate viability score (simplified)
            let marketScore = 0;
            if (market === 'small') marketScore =}\);
   3;
            else if (market === 'medium') marketScore = 6;
            else if (market === 'large') marketScore = 10;
            
            let competitionScore = 0;
            if (competition === 'low') competitionScore = 10;
            else if (competition === 'medium') competitionScore = 6;
            else if (competition === 'high') competitionScore = 3;
            
            const viabilityScore = Math.round((marketScore + competitionScore + problem) / 3);
            
            // Generate recommendation
            let recommendation = '';
            if (viabilityScore >= 7) {
                recommendation = '<span class="status-good">HIGH VIABILITY</span> - This product idea has strong potential. Consider moving forward with development.';
            } else if (viabilityScore >= 4) {
                recommendation = '<span class="status-warning">MEDIUM VIABILITY</span> - This product idea has potential but may require differentiation or niche targeting.';
            } else {
                recommendation = '<span class="status-critical">LOW VIABILITY</span> - This product idea may not be worth pursuing without significant changes to the approach.';
            }
            
            const results = document.getElementById('viability-results');
            results.innerHTML = `
                <h4>Viability Scan Results for: "${idea}"</h4>
                <p><strong>Viability Score:</strong> ${viabilityScore}/10</p>
                <p><strong>Market Size:</strong> ${market}</p>
                <p><strong>Competition Level:</strong> ${competition}</p>
                <p><strong>Problem Solved Rating:</strong> ${problem}/10</p>
                <p><strong>Recommendation:</strong> ${recommendation}</p>
                <p><strong>Next Steps:</strong> ${viabilityScore >= 7 ? 'Proceed to Product Maker to package your idea.' : 'Consider refining your idea or targeting a more specific niche.'}</p>
            `;
            
            addActivity('Viability scan completed', `Score: ${viabilityScore}/10 for "${idea.substring(0, 30)}..."`, 'search', viabilityScore >= 7 ? 'success' : viabilityScore >= 4 ? 'warning' : 'danger');
            alert(`Viability scan completed! Score: ${viabilityScore}/10`);
        }
        
        // Product functions
        function saveProduct() {
            state.data.product = {
                title: document.getElementById('product-title').value,
                type: document.getElementById('product-type').value,
                price: document.getElementById('product-price').value,
                features: document.getElementById('product-features').value,
                bonuses: document.getElementById('product-bonuses').value
            };
            
            localStorage.setItem('readi4bizness_product', JSON.stringify(state.data.product));
            addActivity('Product saved', 'Digital product details stored', 'box-open', 'primary');
            alert('Product details saved!');
        }
        
        function packageProduct() {
            const title = document.getElementById('product-title').value;
            const type = document.getElementById('product-type').value;
            const price = document.getElementById('product-price').value;
            const features = document.getElementById('product-features').value;
            const bonuses = document.getElementById('product-bonuses').value;
            
            if (!title || !price) {
                alert('Please enter product title and price first');
