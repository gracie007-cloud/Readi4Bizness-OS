            }
            
            const output = document.getElementById('product-output');
            output.innerHTML = `
                <h3>${title}</h3>
                <p><strong>Product Type:</strong> ${type}</p>
                <p><strong>Price:</strong> $${parseFloat(price).toFixed(2)}</p>
                
                <h4>Key Features:</h4>
                <ul>${features.split('\n').filter(f => f.trim()).map(f => `<li>${f}</li>`).join('')}</ul>
                
                ${bonuses.trim() ? `
                <h4>Bonuses:</h4>
                <ul>${bonuses.split('\n').filter(b => b.trim()).map(b => `<li>${b}</li>`).join('')}</ul>
                ` : ''}
                
                <h4>Sales Page Outline:</h4>
                <ol>
                    <li>Headline: Solve [problem] with ${title}</li>
                    <li>Problem Agitation: Describe the pain points</li>
                    <li>Solution Introduction: Present ${title} as the solution</li>
                    <li>Features & Benefits: List what's included</li>
                    <li>Social Proof: Customer testimonials</li>
                    <li>Offer & Price: $${parseFloat(price).toFixed(2)}</li>
                    <li>Bonuses: Limited-time extras</li>
                    <li>Guarantee: Risk-free promise</li>
                    <li>Call to Action: Buy now button</li>
                </ol>
            `;
            
            addActivity('Product packaged', `"${title}" ready for launch`, 'box', 'success');
            alert('Product packaged successfully! Ready for launch.');
        }
        
        // Content functions
        function saveContent() {
            const content = {
                title: document.getElementById('content-title').value,
                type: document.getElementById('content-type').value,
                outline: document.getElementById('content-outline').value,
