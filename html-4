<script>
// ==========================================
// State Management
// ==========================================
const DEFAULT_STATE = {
  loggedIn: false,
  currentSection: 'dashboard',
  blueprint: { name:'', tagline:'', mission:'', vision:'', values:'', audience:'', revenue:'', differentiator:'', goals:'' },
  scans: [],
  products: [],
  content: [],
  ads: [],
  affiliates: [],
  activity: []
};

let S = {};

function loadState() {
  try {
    const saved = localStorage.getItem('r4b_state');
    if (saved) { S = JSON.parse(saved); }
    else { S = JSON.parse(JSON.stringify(DEFAULT_STATE)); }
  } catch(e) { S = JSON.parse(JSON.stringify(DEFAULT_STATE)); }
  // Ensure all keys exist
  for (const k in DEFAULT_STATE) { if (!(k in S)) S[k] = DEFAULT_STATE[k]; }
  if (!Array.isArray(S.scans)) S.scans = [];
  if (!Array.isArray(S.products)) S.products = [];
  if (!Array.isArray(S.content)) S.content = [];
  if (!Array.isArray(S.ads)) S.ads = [];
  if (!Array.isArray(S.affiliates)) S.affiliates = [];
  if (!Array.isArray(S.activity)) S.activity = [];
}

function saveState() {
  try { localStorage.setItem('r4b_state', JSON.stringify(S)); } catch(e) {}
}

function addActivity(text, icon) {
  S.activity.unshift({ text, icon, time: new Date().toISOString() });
  if (S.activity.length > 50) S.activity = S.activity.slice(0, 50);
  saveState();
}

// ==========================================
// Toast Notifications
// ==========================================
function showToast(message, type='success') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = 'toast ' + type;
  const icons = { success:'fa-check-circle', error:'fa-exclamation-circle', info:'fa-info-circle' };
  toast.innerHTML = `<i class="fas ${icons[type] || icons.info}"></i><span>${message}</span>`;
  container.appendChild(toast);
  setTimeout(() => { toast.style.opacity='0'; toast.style.transform='translateX(40px)'; toast.style.transition='all .3s'; setTimeout(() => toast.remove(), 300); }, 3000);
}

// ==========================================
// Navigation
// ==========================================
const sectionTitles = {
  dashboard:'Dashboard', blueprint:'Business Blueprint', research:'Product Research',
  product:'Product Maker', content:'Content Planner', promotions:'Promotions', canvas:'Business Canvas'
};

function navigateTo(section) {
  S.currentSection = section;
  saveState();
  // Update nav
  document.querySelectorAll('.nav-item[data-section]').forEach(n => {
    n.classList.toggle('active', n.dataset.section === section);
  });
  // Update sections
  document.querySelectorAll('.section').forEach(s => {
    s.classList.toggle('active', s.id === 'section-' + section);
  });
  // Update topbar
  document.getElementById('topbar-title').textContent = sectionTitles[section] || section;
  // Close mobile sidebar
  document.getElementById('sidebar').classList.remove('open');
  // Refresh section data
  refreshSection(section);
}

function refreshSection(section) {
  if (section === 'dashboard') renderDashboard();
  if (section === 'blueprint') loadBlueprint();
  if (section === 'research') renderScanHistory();
  if (section === 'product') renderProducts();
  if (section === 'content') renderContent();
  if (section === 'promotions') { renderAds(); renderAffiliates(); }
}

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}

// ==========================================
// Auth
// ==========================================
function handleLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pass = document.getElementById('login-pass').value;
  const errEl = document.getElementById('login-error');
  if (email === 'demo@readi4bizness.com' && pass === 'readi-demo-2026') {
    S.loggedIn = true;
    saveState();
    errEl.style.display = 'none';
    document.getElementById('login-overlay').classList.add('hidden');
    document.getElementById('app').style.display = 'block';
    navigateTo(S.currentSection || 'dashboard');
    addActivity('Signed in to Readi4Bizness OS', 'fa-right-to-bracket');
    showToast('Welcome to Readi4Bizness OS');
  } else {
    errEl.style.display = 'block';
    document.getElementById('login-card').classList.add('shake');
    setTimeout(() => document.getElementById('login-card').classList.remove('shake'), 400);
  }
}

function handleLogout() {
  S.loggedIn = false;
  saveState();
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-overlay').classList.remove('hidden');
  document.getElementById('login-email').value = '';
  document.getElementById('login-pass').value = '';
  showToast('Signed out successfully', 'info');
}

function checkAuth() {
  loadState();
  if (S.loggedIn) {
    document.getElementById('login-overlay').classList.add('hidden');
    document.getElementById('app').style.display = 'block';
    navigateTo(S.currentSection || 'dashboard');
  }
}

// Enter key for login
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !S.loggedIn) handleLogin();
});

// ==========================================
// Date display
// ==========================================
function updateDate() {
  const now = new Date();
  const opts = { weekday:'long', year:'numeric', month:'long', day:'numeric' };
  document.getElementById('topbar-date').textContent = now.toLocaleDateString('en-US', opts);
}

// ==========================================
// Dashboard
// ==========================================
function renderDashboard() {
  // Blueprint progress
  const bpFields = Object.values(S.blueprint).filter(v => v.trim && v.trim() !== '');
  const bpTotal = Object.keys(S.blueprint).length;
  const bpPct = bpTotal > 0 ? Math.round((bpFields.length / bpTotal) * 100) : 0;
  document.getElementById('stat-blueprint').textContent = bpPct + '%';
  document.getElementById('bar-blueprint').style.width = bpPct + '%';

  // Products
  document.getElementById('stat-products').textContent = S.products.length;
  document.getElementById('bar-products').style.width = Math.min(S.products.length * 25, 100) + '%';

  // Content
  document.getElementById('stat-content').textContent = S.content.length;
  document.getElementById('bar-content').style.width = Math.min(S.content.length * 10, 100) + '%';

  // Campaigns
  const totalCampaigns = S.ads.length + S.affiliates.length;
  document.getElementById('stat-campaigns').textContent = totalCampaigns;
  document.getElementById('bar-campaigns').style.width = Math.min(totalCampaigns * 20, 100) + '%';

  // Activity feed
  const feed = document.getElementById('activity-feed');
  if (S.activity.length === 0) {
    feed.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:20px 0;text-align:center;">No activity yet. Start building your business.</div>';
  } else {
    feed.innerHTML = S.activity.slice(0, 20).map(a => {
      const d = new Date(a.time);
      const timeStr = d.toLocaleDateString('en-US', {month:'short',day:'numeric'}) + ' ' + d.toLocaleTimeString('en-US', {hour:'2-digit',minute:'2-digit'});
      return `<div class="activity-item"><i class="fas ${a.icon}" style="color:var(--accent);margin-top:2px;width:16px;text-align:center;"></i><div><div style="color:var(--fg);">${a.text}</div><div style="color:var(--muted);font-size:11px;margin-top:2px;">${timeStr}</div></div></div>`;
    }).join('');
  }
}

// ==========================================
// Blueprint
// ==========================================
function loadBlueprint() {
  const fields = ['name','tagline','mission','vision','values','audience','revenue','differentiator','goals'];
  fields.forEach(f => {
    const el = document.getElementById('bp-' + f);
    if (el && S.blueprint[f] !== undefined) el.value = S.blueprint[f];
  });
}

function saveBlueprint() {
  const fields = ['name','tagline','mission','vision','values','audience','revenue','differentiator','goals'];
  fields.forEach(f => {
    const el = document.getElementById('bp-' + f);
    if (el) S.blueprint[f] = el.value;
  });
  saveState();
  addActivity('Updated Business Blueprint', 'fa-drafting-compass');
  showToast('Blueprint saved successfully');
}

// ==========================================
// Research / Viability Scan
// ==========================================
function runViabilityScan() {
  const name = document.getElementById('rs-name').value.trim();
  const niche = document.getElementById('rs-niche').value.trim();
  const desc = document.getElementById('rs-desc').value.trim();
  if (!name) { showToast('Enter a product name first', 'error'); return; }

  const demand = parseInt(document.getElementById('rs-demand').value);
  const competition = parseInt(document.getElementById('rs-competition').value);
  const severity = parseInt(document.getElementById('rs-severity').value);
  const expertise = parseInt(document.getElementById('rs-expertise').value);
  const monetize = parseInt(document.getElementById('rs-monetize').value);

  // Weighted score (competition is inverse)
  const score = Math.round(
    (demand * 0.25) +
    ((10 - competition) * 0.15) +
    (severity * 0.20) +
    (expertise * 0.15) +
    (monetize * 0.25)
  );

  let verdict, verdictColor, verdictBadge;
  if (score >= 75) { verdict = 'Highly Viable'; verdictColor = '#00E676'; verdictBadge = 'badge-green'; }
  else if (score >= 55) { verdict = 'Promising'; verdictColor = '#FFD600'; verdictBadge = 'badge-orange'; }
  else if (score >= 35) { verdict = 'Needs Refinement'; verdictColor = '#FF9100'; verdictBadge = 'badge-orange'; }
  else { verdict = 'Low Viability'; verdictColor = '#FF4757'; verdictBadge = 'badge-red'; }

  const scan = { name, niche, desc, demand, competition, severity, expertise, monetize, score, verdict, time: new Date().toISOString() };
  S.scans.unshift(scan);
  if (S.scans.length > 20) S.scans = S.scans.slice(0, 20);
  saveState();
  addActivity(`Ran viability scan for "${name}" — Score: ${score}/100`, 'fa-microscope');

  // Render result
  const card = document.getElementById('scan-result-card');
  const circumference = 2 * Math.PI * 70;
  const offset = circumference - (score / 100) * circumference;
  card.innerHTML = `
    <svg width="160" height="160" viewBox="0 0 160 160" style="margin-bottom:16px;">
      <circle cx="80" cy="80" r="70" stroke="var(--border)" stroke-width="8" fill="none"/>
      <circle cx="80" cy="80" r="70" stroke="${verdictColor}" stroke-width="8" fill="none"
        stroke-dasharray="${circumference}" stroke-dashoffset="${circumference}" stroke-linecap="round"
        transform="rotate(-90 80 80)" class="gauge-ring" id="gauge-circle" style="transition:stroke-dashoffset 1.2s cubic-bezier(.22,1,.36,1);"/>
      <text x="80" y="74" text-anchor="middle" fill="${verdictColor}" font-size="32" font-weight="700" font-family="Space Grotesk">${score}</text>
      <text x="80" y="96" text-anchor="middle" fill="var(--muted)" font-size="12" font-family="DM Sans">/ 100</text>
    </svg>
    <div style="font-size:18px;font-weight:700;color:${verdictColor};margin-bottom:4px;">${verdict}</div>
    <div style="color:var(--muted);font-size:13px;margin-bottom:16px;">${name}${niche ? ' — ' + niche : ''}</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;text-align:left;width:100%;">
      <div style="font-size:12px;"><span style="color:var(--muted);">Demand:</span> <span style="color:var(--fg);font-weight:600;">${demand}/10</span></div>
      <div style="font-size:12px;"><span style="color:var(--muted);">Competition:</span> <span style="color:var(--fg);font-weight:600;">${competition}/10</span></div>
      <div style="font-size:12px;"><span style="color:var(--muted);">Severity:</span> <span style="color:var(--fg);font-weight:600;">${severity}/10</span></div>
      <div style="font-size:12px;"><span style="color:var(--muted);">Expertise:</span> <span style="color:var(--fg);font-weight:600;">${expertise}/10</span></div>
      <div style="font-size:12px;grid-column:span 2;"><span style="color:var(--muted);">Monetization:</span> <span style="color:var(--fg);font-weight:600;">${monetize}/10</span></div>
    </div>
  `;
  // Animate gauge
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      document.getElementById('gauge-circle').style.strokeDashoffset = offset;
    });
  });
  renderScanHistory();
  showToast(`Viability score: ${score}/100 — ${verdict}`, score >= 55 ? 'success' : 'error');
}

function renderScanHistory() {
  const el = document.getElementById('scan-history');
  if (S.scans.length === 0) { el.innerHTML = ''; return; }
  let html = '<h3 style="font-size:14px;font-weight:600;margin-bottom:10px;color:var(--muted);">Scan History</h3>';
  html += S.scans.slice(0, 8).map((s, i) => {
    const d = new Date(s.time);
    const ds = d.toLocaleDateString('en-US', {month:'short',day:'numeric'});
    let badge = s.score >= 75 ? 'badge-green' : s.score >= 55 ? 'badge-orange' : s.score >= 35 ? 'badge-orange' : 'badge-red';
    return `<div class="item-card" style="display:flex;justify-content:space-between;align-items:center;"><div><span style="font-weight:600;font-size:14px;">${s.name}</span><span style="color:var(--muted);font-size:12px;margin-left:8px;">${ds}</span></div><span class="badge ${badge}">${s.score}/100</span></div>`;
  }).join('');
  el.innerHTML = html;
}

// ==========================================
// Product Maker
// ==========================================
function addProduct() {
  const name = document.getElementById('pm-name').value.trim();
  const type = document.getElementById('pm-type').value;
  const price = parseFloat(document.getElementById('pm-price').value) || 0;
  const delivery = document.getElementById('pm-delivery').value;
  const desc = document.getElementById('pm-desc').value.trim();
  const modulesRaw = document.getElementById('pm-modules').value.trim();
  const modules = modulesRaw ? modulesRaw.split('\n').map(m => m.trim()).filter(m => m) : [];

  if (!name) { showToast('Product name is required', 'error'); return; }

  S.products.push({ id: Date.now(), name, type, price, delivery, desc, modules });
  saveState();
  addActivity(`Created product: "${name}" (${type})`, 'fa-box-open');

  // Clear form
  document.getElementById('pm-name').value = '';
  document.getElementById('pm-price').value = '';
  document.getElementById('pm-desc').value = '';
  document.getElementById('pm-modules').value = '';

  renderProducts();
  showToast('Product added successfully');
}

function renderProducts() {
  const el = document.getElementById('product-list');
  if (S.products.length === 0) {
    el.innerHTML = '<div style="color:var(--muted);font-size:14px;text-align:center;padding:30px 0;">No products yet. Create your first one above.</div>';
    return;
  }
  const typeIcons = { ebook:'fa-book', course:'fa-graduation-cap', template:'fa-layer-group', tool:'fa-wrench', coaching:'fa-comments', bundle:'fa-boxes-stacked' };
  const deliveryLabels = { download:'Digital Download', membership:'Membership', cohort:'Cohort-Based', drip:'Drip Content' };
  el.innerHTML = S.products.map(p => `
    <div class="item-card">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
        <div>
          <span style="font-weight:600;font-size:16px;"><i class="fas ${typeIcons[p.type]||'fa-cube'}" style="color:var(--accent2);margin-right:8px;"></i>${p.name}</span>
          <span class="badge badge-orange" style="margin-left:8px;">${p.type}</span>
          <span class="badge badge-blue" style="margin-left:4px;">${deliveryLabels[p.delivery]||p.delivery}</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
          <span style="font-weight:700;font-size:18px;color:var(--accent);">$${p.price.toFixed(0)}</span>
          <button class="btn-danger btn-sm" onclick="deleteProduct(${p.id})"><i class="fas fa-trash"></i></button>
        </div>
      </div>
      ${p.desc ? `<div style="color:var(--muted);font-size:13px;margin-bottom:8px;">${p.desc}</div>` : ''}
      ${p.modules.length > 0 ? `<div style="display:flex;flex-wrap:wrap;gap:6px;">${p.modules.map((m,i) => `<span style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:4px 10px;font-size:12px;"><span style="color:var(--accent);font-weight:600;">${i+1}.</span> ${m}</span>`).join('')}</div>` : ''}
    </div>
  `).join('');
}

function deleteProduct(id) {
  S.products = S.products.filter(p => p.id !== id);
  saveState();
  addActivity('Deleted a product', 'fa-trash');
  renderProducts();
  showToast('Product removed', 'info');
}

// ==========================================
// Content Planner
// ==========================================
let contentFilter = 'all';

function addContent() {
  const title = document.getElementById('ct-title').value.trim();
  const type = document.getElementById('ct-type').value;
  const status = document.getElementById('ct-status').value;
  if (!title) { showToast('Content title is required', 'error'); return; }

  S.content.push({ id: Date.now(), title, type, status });
  saveState();
  addActivity(`Added content: "${title}" [${type}]`, 'fa-pen-nib');
  document.getElementById('ct-title').value = '';
  renderContent();
  showToast('Content item added');
}

function renderContent() {
  const el = document.getElementById('content-list');
  let items = S.content;
  if (contentFilter !== 'all') items = items.filter(c => c.type === contentFilter);

  if (items.length === 0) {
    el.innerHTML = '<div style="color:var(--muted);font-size:14px;text-align:center;padding:30px 0;">No content items yet.</div>';
    return;
  }

  const statusBadges = { idea:'badge-gray', draft:'badge-orange', scheduled:'badge-blue', published:'badge-green' };
  const typeIcons = { blog:'fa-newspaper', course:'fa-graduation-cap', video:'fa-video', social:'fa-hashtag', email:'fa-envelope' };

  el.innerHTML = items.map(c => `
    <div class="item-card" style="display:flex;justify-content:space-between;align-items:center;gap:12px;">
      <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0;">
        <i class="fas ${typeIcons[c.type]||'fa-file'}" style="color:var(--info);width:18px;text-align:center;flex-shrink:0;"></i>
        <span style="font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${c.title}</span>
        <span class="badge badge-blue" style="flex-shrink:0;">${c.type}</span>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <select class="r4b-input" style="width:auto;padding:4px 28px 4px 10px;font-size:12px;" onchange="updateContentStatus(${c.id},this.value)">
          <option value="idea" ${c.status==='idea'?'selected':''}>Idea</option>
          <option value="draft" ${c.status==='draft'?'selected':''}>Draft</option>
          <option value="scheduled" ${c.status==='scheduled'?'selected':''}>Scheduled</option>
          <option value="published" ${c.status==='published'?'selected':''}>Published</option>
        </select>
        <span class="badge ${statusBadges[c.status]}">${c.status}</span>
        <button class="btn-danger btn-sm" onclick="deleteContent(${c.id})" style="padding:4px 10px;"><i class="fas fa-trash" style="font-size:11px;"></i></button>
      </div>
    </div>
  `).join('');
}

function updateContentStatus(id, status) {
  const item = S.content.find(c => c.id === id);
  if (item) { item.status = status; saveState(); renderContent(); }
}

function deleteContent(id) {
  S.content = S.content.filter(c => c.id !== id);
  saveState();
  renderContent();
  showToast('Content item removed', 'info');
}

function filterContent(type, btn) {
  contentFilter = type;
  document.querySelectorAll('#content-filters .sub-tab').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  renderContent();
}

// ==========================================
// Promotions
// ==========================================
function switchPromoTab(tab) {
  document.getElementById('promo-ads').style.display = tab === 'ads' ? 'block' : 'none';
  document.getElementById('promo-affiliates').style.display = tab === 'affiliates' ? 'block' : 'none';
  document.getElementById('promo-tab-ads').classList.toggle('active', tab === 'ads');
  document.getElementById('promo-tab-affiliates').classList.toggle('active', tab === 'affiliates');
}

function addAd() {
  const platform = document.getElementById('ad-platform').value;
  const budget = parseFloat(document.getElementById('ad-budget').value) || 0;
  const duration = parseInt(document.getElementById('ad-duration').value);
  const target = document.getElementById('ad-target').value.trim();
  if (budget <= 0) { showToast('Enter a valid budget', 'error'); return; }

  S.ads.push({ id: Date.now(), platform, budget, duration, target });
  saveState();
  addActivity(`Created ad campaign: ${platform} — $${budget}/${duration}d`, 'fa-bullhorn');
  document.getElementById('ad-budget').value = '';
  document.getElementById('ad-target').value = '';
  renderAds();
  showToast('Ad campaign created');
}

function renderAds() {
  const el = document.getElementById('ads-list');
  if (S.ads.length === 0) {
    el.innerHTML = '<div style="color:var(--muted);font-size:14px;text-align:center;padding:20px 0;">No ad campaigns yet.</div>';
    return;
  }
  const platformIcons = { meta:'fa-meta', google:'fa-google', tiktok:'fa-tiktok', youtube:'fa-youtube', linkedin:'fa-linkedin', twitter:'fa-x-twitter' };
  el.innerHTML = S.ads.map(a => `
    <div class="item-card" style="display:flex;justify-content:space-between;align-items:center;">
      <div style="display:flex;align-items:center;gap:12px;">
        <i class="fab ${platformIcons[a.platform]||'fa-ad'}" style="color:var(--accent2);font-size:18px;width:24px;text-align:center;"></i>
        <div>
          <span style="font-weight:600;text-transform:capitalize;">${a.platform}</span>
          <span style="color:var(--muted);font-size:12px;margin-left:8px;">${a.duration}d</span>
          ${a.target ? `<div style="color:var(--muted);font-size:12px;">${a.target}</div>` : ''}
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-weight:700;color:var(--accent);">$${a.budget.toLocaleString()}</span>
        <span style="color:var(--muted);font-size:12px;">$${(a.budget/a.duration).toFixed(0)}/d</span>
        <button class="btn-danger btn-sm" onclick="deleteAd(${a.id})"><i class="fas fa-trash"></i></button>
      </div>
    </div>
  `).join('');
}

function deleteAd(id) {
  S.ads = S.ads.filter(a => a.id !== id);
  saveState(); renderAds(); showToast('Campaign removed', 'info');
}

function addAffiliate() {
  const name = document.getElementById('aff-name').value.trim();
  const commission = parseInt(document.getElementById('aff-commission').value) || 0;
  const product = document.getElementById('aff-product').value.trim();
  if (!name) { showToast('Partner name is required', 'error'); return; }

  S.affiliates.push({ id: Date.now(), name, commission, product });
  saveState();
  addActivity(`Added affiliate partner: ${name} (${commission}%)`, 'fa-handshake');
  document.getElementById('aff-name').value = '';
  document.getElementById('aff-commission').value = '';
  document.getElementById('aff-product').value = '';
  renderAffiliates();
  showToast('Affiliate partner added');
}

function renderAffiliates() {
  const el = document.getElementById('affiliates-list');
  if (S.affiliates.length === 0) {
    el.innerHTML = '<div style="color:var(--muted);font-size:14px;text-align:center;padding:20px 0;">No affiliate partners yet.</div>';
    return;
  }
  el.innerHTML = S.affiliates.map(a => `
    <div class="item-card" style="display:flex;justify-content:space-between;align-items:center;">
      <div style="display:flex;align-items:center;gap:12px;">
        <i class="fas fa-handshake" style="color:var(--accent);font-size:18px;"></i>
        <div>
          <span style="font-weight:600;">${a.name}</span>
          ${a.product ? `<div style="color:var(--muted);font-size:12px;">${a.product}</div>` : ''}
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <span class="badge badge-green">${a.commission}% commission</span>
        <button class="btn-danger btn-sm" onclick="deleteAffiliate(${a.id})"><i class="fas fa-trash"></i></button>
      </div>
    </div>
  `).join('');
}

function deleteAffiliate(id) {
  S.affiliates = S.affiliates.filter(a => a.id !== id);
  saveState(); renderAffiliates(); showToast('Affiliate removed', 'info');
}

// ==========================================
// Canvas / Export
// ==========================================
let canvasText = '';

function generateCanvas() {
  let doc = '';
  const sep = '\u2550'.repeat(52);
  const thinSep = '\u2500'.repeat(52);

  doc += '\u2564' + sep + '\u2557\n';
  doc += '\u2551   READI4BIZNESS \u2014 BUSINESS CANVAS' + ' '.repeat(18) + '\u2551\n';
  doc += '\u255A' + sep + '\u255D\n\n';
  doc += `Generated: ${new Date().toLocaleString()}\n\n`;

  // Blueprint
  doc += '\u25B6 BUSINESS BLUEPRINT\n' + thinSep + '\n';
  const bp = S.blueprint;
  if (bp.name) doc += `Business Name:    ${bp.name}\n`;
  if (bp.tagline) doc += `Tagline:          ${bp.tagline}\n`;
  if (bp.mission) doc += `Mission:          ${bp.mission}\n`;
  if (bp.vision) doc += `Vision:           ${bp.vision}\n`;
  if (bp.values) doc += `Core Values:      ${bp.values}\n`;
  if (bp.audience) doc += `Target Audience:  ${bp.audience}\n`;
  if (bp.revenue) doc += `Revenue Model:    ${bp.revenue}\n`;
  if (bp.differentiator) doc += `Differentiator:   ${bp.differentiator}\n`;
  if (bp.goals) doc += `90-Day Goals:     ${bp.goals}\n`;
  if (Object.values(bp).every(v => !v || (v.trim && v.trim()===''))) doc += '(No blueprint data yet)\n';
  doc += '\n';

  // Research
  doc += '\u25B6 PRODUCT RESEARCH\n' + thinSep + '\n';
  if (S.scans.length > 0) {
    S.scans.slice(0, 5).forEach((s, i) => {
      doc += `${i+1}. ${s.name} (${s.niche || 'No niche'}) \u2014 Score: ${s.score}/100 [${s.verdict}]\n`;
      doc += `   Demand:${s.demand} Competition:${s.competition} Severity:${s.severity} Expertise:${s.expertise} Monetization:${s.monetize}\n`;
    });
  } else {
    doc += '(No viability scans yet)\n';
  }
  doc += '\n';

  // Products
  doc += '\u25B6 DIGITAL PRODUCTS\n' + thinSep + '\n';
  if (S.products.length > 0) {
    S.products.forEach((p, i) => {
      doc += `${i+1}. ${p.name} [${p.type}] \u2014 $${p.price}\n`;
      if (p.delivery) doc += `   Delivery: ${p.delivery}\n`;
      if (p.desc) doc += `   ${p.desc}\n`;
      if (p.modules.length) doc += `   Modules: ${p.modules.join(', ')}\n`;
    });
  } else {
    doc += '(No products yet)\n';
  }
  doc += '\n';

  // Content
  doc += '\u25B6 CONTENT PLAN\n' + thinSep + '\n';
  if (S.content.length > 0) {
    S.content.forEach((c, i) => {
      doc += `${i+1}. ${c.title} [${c.type}] \u2014 ${c.status.toUpperCase()}\n`;
    });
  } else {
    doc += '(No content items yet)\n';
  }
  doc += '\n';

  // Promotions
  doc += '\u25B6 AD CAMPAIGNS\n' + thinSep + '\n';
  if (S.ads.length > 0) {
    S.ads.forEach((a, i) => {
      doc += `${i+1}. ${a.platform.toUpperCase()} \u2014 $${a.budget} / ${a.duration}d${a.target ? ' \u2014 ' + a.target : ''}\n`;
    });
  } else {
    doc += '(No ad campaigns yet)\n';
  }
  doc += '\n';

  doc += '\u25B6 AFFILIATE PARTNERS\n' + thinSep + '\n';
  if (S.affiliates.length > 0) {
    S.affiliates.forEach((a, i) => {
      doc += `${i+1}. ${a.name} \u2014 ${a.commission}%${a.product ? ' \u2014 ' + a.product : ''}\n`;
    });
  } else {
    doc += '(No affiliates yet)\n';
  }
  doc += '\n' + thinSep + '\nEnd of Business Canvas\n';

  canvasText = doc;

  // Render preview
  const el = document.getElementById('canvas-output');
  el.innerHTML = `<pre style="white-space:pre-wrap;word-break:break-word;font-family:'Space Grotesk',monospace;font-size:13px;line-height:1.7;color:var(--fg);padding:4px;">${escapeHtml(doc)}</pre>`;
  document.getElementById('btn-export').style.display = 'inline-flex';
  document.getElementById('btn-copy').style.display = 'inline-flex';
  addActivity('Generated Business Canvas document', 'fa-file-export');
  showToast('Canvas generated successfully');
}

function exportCanvas() {
  if (!canvasText) return;
  const blob = new Blob([canvasText], { type: 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `readi4bizness-canvas-${Date.now()}.txt`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showToast('Canvas exported as .txt file');
}

function copyCanvas() {
  if (!canvasText) return;
  navigator.clipboard.writeText(canvasText).then(() => {
    showToast('Canvas copied to clipboard');
  }).catch(() => {
    showToast('Failed to copy', 'error');
  });
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

// ==========================================
// Init
// ==========================================
function init() {
  loadState();
  updateDate();
  setInterval(updateDate, 60000);
  checkAuth();
}

document.addEventListener('DOMContentLoaded', init);

// Close sidebar on outside click (mobile)
document.addEventListener('click', e => {
  const sidebar = document.getElementById('sidebar');
  const hamburger = document.getElementById('hamburger');
  if (window.innerWidth <= 768 && sidebar.classList.contains('open') && !sidebar.contains(e.target) && !hamburger.contains(e.target)) {
    sidebar.classList.remove('open');
  }
});
</script>
