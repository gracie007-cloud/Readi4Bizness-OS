                logActivity(`Campaign ${campaign.status}: ${campaign.name}`);
            }
        }
        
        function deleteCampaign(id) {
            if (confirm('Delete this campaign?')) {
                state.promotions.campaigns = state.promotions.campaigns.filter(c => c.id !== id);
                saveState();
                renderCampaignsList();
                updateDashboardStats();
                logActivity('Campaign deleted');
                showToast('Campaign deleted', 'info');
            }
        }
        
        function addAffiliate() {
            const affiliate = {
                id: Date.now(),
                name: document.getElementById('aff-name').value.trim(),
                commission: parseInt(document.getElementById('aff-commission').value) || 0,
                product: document.getElementById('aff-product').value.trim(),
                notes: document.getElementById('aff-notes').value.trim(),
                timestamp: new Date().toISOString(),
                status: 'active'
            };
            
            if (!affiliate.name) {
                showToast('Partner name is required', 'error');
                return;
            }
            
            state.promotions.affiliates.push(affiliate);
            saveState();
            
            // Clear form
            document.getElementById('aff-name').value = '';
            document.getElementById('aff-commission').value = '';
            document.getElementById('aff-product').value = '';
            document.getElementById('aff-notes').value = '';
            
            renderAffiliatesList();
            updateDashboardStats();
            logActivity(`Affiliate added: ${affiliate.name}`);
            showToast('Affiliate partner added', 'success');
        }
        
        function renderAffiliatesList() {
            const container = document.getElementById('affiliates-list');
            if (!container) return;
            
            if (state.promotions.affiliates.length === 0) {
                container.innerHTML = '<p style="color: var(--text-muted); text-align: center;">No affiliate partners</p>';
                return;
            }
            
            container.innerHTML = state.promotions.affiliates.map(affiliate => {
                const time = new Date(affiliate.timestamp);
                const timeStr = time.toLocaleDateString([], { month: 'short', day: 'numeric' });
                
                return `
                    <div style="padding: 16px; border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 12px;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                            <div>
                                <div style="font-weight: 600; font-size: 16px;">${affiliate.name}</div>
                                <div style="font-size: 14px; color: var(--text-muted);">Added ${timeStr}</div>
                                ${affiliate.product ? `<div style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">Product: ${affiliate.product}</div>` : ''}
                            </div>
                            <div style="font-weight: 700; color: var(--accent);">${affiliate.commission}%</div>
                        </div>
                        ${affiliate.notes ? `<div style="font-size: 13px; color: var(--text-muted); margin-top: 8px;">${affiliate.notes}</div>` : ''}
                        <div style="display: flex; gap: 8px; margin-top: 12px;">
                            <button class="btn btn-sm btn-danger" onclick="deleteAffiliate(${affiliate.id})">
                                <i class="fas fa-trash"></i> Remove
                            </button>
                        </div>
                    </div>
                `;
            }).join('');
        }
        
        function deleteAffiliate(id) {
            if (confirm('Remove this affiliate partner?')) {
                state.promotions.affiliates = state.promotions.affiliates.filter(a => a.id !== id);
                saveState();
                renderAffiliatesList();
                updateDashboardStats();
                logActivity('Affiliate partner removed');
                showToast('Affiliate partner removed', 'info');
            }
        }
        
        // ==========================================
        // Canvas Export Module
        // ==========================================
        function loadCanvasContent() {
            const editor = document.getElementById('canvas-editor');
            const title = document.getElementById('canvas-title');
            
            if (state.canvas.content && editor) {
                editor.innerHTML = state.canvas.content;
            }
            
            if (state.canvas.title && title) {
                title.value = state.canvas.title;
            }
            
            // Set up auto-save
            const interval = document.getElementById('auto-save');
            if (interval && state.settings.autoSaveInterval) {
                interval.value = state.settings.autoSaveInterval;
            }
            
            setupAutoSave();
        }
        
        function saveCanvas() {
            const editor = document.getElementById('canvas-editor');
            const title = document.getElementById('canvas-title');
            
            if (editor) {
                state.canvas.content = editor.innerHTML;
            }
            
            if (title) {
                state.canvas.title = title.value;
            }
            
            saveState();
            logActivity('Canvas document saved');
            showToast('Canvas saved', 'success');
        }
        
        function setupAutoSave() {
            const intervalInput = document.getElementById('auto-save');
            const editor = document.getElementById('canvas-editor');
            
            if (!intervalInput || !editor) return;
            
            let timeout;
            
            function scheduleSave() {
                clearTimeout(timeout);
                timeout = setTimeout(() => {
                    saveCanvas();
                }, parseInt(intervalInput.value) * 1000);
            }
            
            intervalInput.addEventListener('change', function() {
                state.settings.autoSaveInterval = parseInt(this.value);
                saveState();
                scheduleSave();
            });
            
            editor.addEventListener('input', scheduleSave);
            
            // Initial schedule
            scheduleSave();
        }
        
        function formatText(command) {
            document.execCommand(command, false, null);
            document.getElementById('canvas-editor').focus();
        }
        
        function clearCanvas() {
            if (confirm('Clear the canvas? This cannot be undone.')) {
                document.getElementById('canvas-editor').innerHTML = '';
                state.canvas.content = '';
                saveState();
                logActivity('Canvas cleared');
                showToast('Canvas cleared', 'info');
            }
        }
        
        function generateCompositeCanvas() {
            const output = `
