        function exportCanvasText() {
            const content = document.getElementById('composite-content').textContent || state.canvas.content;
            const title = state.canvas.title || 'business-canvas';
            exportAsTextFile(content, `${title}.txt`);
            logActivity('Canvas exported as text');
            showToast('Canvas exported', 'success');
        }
        
        function copyCanvasToClipboard() {
            const content = document.getElementById('composite-content').textContent || state.canvas.content;
            navigator.clipboard.writeText(content).then(() => {
                showToast('Canvas copied to clipboard', 'success');
            }).catch(() => {
                showToast('Failed to copy to clipboard', 'error');
            });
