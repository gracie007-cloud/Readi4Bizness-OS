        // ==========================================
        // Data Backup & Export
        // ==========================================
        function exportAllData() {
            const data = {
                exported: new Date().toISOString(),
                state: state,
                version: '1.0'
            };
            
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `readi4bizness-backup-${new Date().toISOString().slice(0,10)}.json`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            
            logActivity('All data exported');
            showToast('Backup file downloaded', 'success');
        }
        
        function importAllData() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            
            input.onchange = function(e) {
                const file = e.target.files[0];
                const reader = new FileReader();
                
                reader.onload = function(event) {
                    try {
                        const imported = JSON.parse(event.target.result);
                        
                        if (confirm('This will replace all current data. Continue?')) {
                            state = imported.state || getDefaultState();
                            saveState();
                            
                            // Refresh UI
                            initializeModules();
                            navigateTo(state.currentPage || 'dashboard');
                            
                            logActivity('All data imported from backup');
                            showToast('Data restored from backup', 'success');
                        }
                    } catch (error) {
                        showToast('Invalid backup file', 'error');
                    }
                };
                
                reader.readAsText(file);
            };
            
            input.click();
        }
        
        function clearAllData() {
            if (confirm('This will delete ALL data including blueprints, products, content, and campaigns. This cannot be undone. Continue?')) {
                state = getDefaultState();
                saveState();
                
                // Reset UI
                initializeModules();
                navigateTo('dashboard');
                
                logActivity('All data cleared');
                showToast('All data has been cleared', 'info');
            }
        }
        
        // ==========================================
        // Utility Functions
        // ==========================================
        function exportAsTextFile(content, filename) {
            const blob = new Blob([content], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }
        
        // ==========================================
        // Initialization
        // ==========================================
        document.addEventListener('DOMContentLoaded', function() {
            // Load state
            loadState();
            
            // Set up login form
            document.getElementById('loginForm').addEventListener('submit', handleLogin);
            
            // Set up logout button
            document.getElementById('logoutBtn').addEventListener('click', handleLogout);
            
            // Set up navigation
            document.querySelectorAll('.nav-item').forEach(item => {
                item.addEventListener('click', function() {
                    navigateTo(this.dataset.page);
                });
                
                // Add keyboard support
                item.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        navigateTo(this.dataset.page);
                        e.preventDefault();
                    }
                });
            });
            
            // Check if already logged in
            if (state.loggedIn) {
                document.getElementById('loginModal').style.display = 'none';
                document.getElementById('app').classList.add('active');
                initializeModules();
                navigateTo(state.currentPage || 'dashboard');
            }
            
            // Add ARIA labels for accessibility
            document.querySelectorAll('[data-page]').forEach(el => {
                el.setAttribute('aria-label', `Navigate to ${el.dataset.page}`);
            });
            
            // Initialize range inputs
            updateRangeDisplays();
        });
    </script>
