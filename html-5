        function runViabilityScan() {
            const idea = document.getElementById('rs-idea').value.trim();
            const category = document.getElementById('rs-category').value;
            const description = document.getElementById('rs-description').value.trim();
            
            if (!idea) {
                showToast('Please enter a product idea first', 'error');
                return;
            }
            
            const demand = parseInt(document.getElementById('rs-demand').value);
            const competition = parseInt(document.getElementById('rs-competition').value);
            const severity = parseInt(document.getElementById('rs-severity').value);
            const expertise = parseInt(document.getElementById('rs-expertise').value);
            
            // Weighted scoring algorithm
            const score = Math.round(
                (demand * 0.25) +
                ((10 - competition) * 0.20) + // Lower competition is better
                (severity * 0.30) +
                (expertise * 0.25)
            );
            
            let verdict, verdictClass;
            if (score >= 75) {
                verdict = 'High Viability';
                verdictClass = 'badge-success';
            } else if (score >=46:
   50) {
                verdict = 'Moderate Viability';
                verdictClass = 'badge-warning';
            } else {
                verdict = 'Low Viability';
                verdictClass = 'badge-danger';
            }
            
            const scan = {
                id: Date.now(),
                idea,
                category,
                description,
                demand,
                competition,
                severity,
                expertise,
                score,
                verdict,
                timestamp: new Date().toISOString()
            };
            
            state.research.scans.unshift(scan);
            state.research.currentScan = scan;
            saveState();
            
            // Display results
            const resultsDiv = document.getElementById('scan-results');
            resultsDiv.innerHTML = `
                <div style="text-align: center; margin-bottom: 24px;">
                    <div style="font-size: 48px; font-weight: 700; color: var(--accent); margin-bottom: 8px;">${score}/100</div>
                    <div class="badge ${verdictClass}" style="font-size: 16px; padding: 8px 16px;">${verdict}</div>
                </div>
                
                <div style="background: var(--surface-alt); padding: 16px; border-radius: var(--radius); margin-bottom: 16px;">
                    <h4 style="margin-bottom: 8px; color: var(--text);">${idea}</h4>
                    <p style="color: var(--text-muted); font-size: 14px;">${category ? category.charAt(0).toUpperCase() + category.slice(1) : 'No category'} | ${description || 'No description'}</p>
                </div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <div>
                        <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Market Demand</div>
                        <div style="font-weight: 600; font-size: 18px;">${demand}/10</div>
                    </div>
                    <div>
                        <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Competition Level</div>
                        <div style="font-weight: 600; font-size: 18px;">${competition}/10</div>
                    </div>
                    <div>
                        <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Problem Severity</div>
                        <div style="font-weight: 600; font-size: 18px;">${severity}/10</div>
                    </div>
                    <div>
                        <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Your Expertise</div>
                        <div style="font-weight: 600; font-size: 18px;">${expertise}/10</div>
                    </div>
                </div>
                
                <div style="margin-top: 20px; padding: 16px; background: var(--surface-alt); border-radius: var(--radius);">
                    <h5 style="margin-bottom: -8px; color: var(--text);">Recommendation</h5>
                    <p style="color: var(--text-muted); font-size: 14px;">
                        ${score >= 75 ? 'Proceed with confidence. This product has strong market potential.' :
                          score >= 50 ? 'Consider refining your approach or targeting a more specific niche.' :
                          'Reevaluate the concept or explore different market segments.'}
                    </p>
                </div>
