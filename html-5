    <script>
        // ==========================================
        // State Management
        // ==========================================
        const STORAGE_KEY = 'readi4bizness_os';
        
        function getDefaultState() {
            return {
                loggedIn: false,
                currentPage: 'dashboard',
                blueprint: {
                    name: '',
                    tagline: '',
                    mission: '',
                    vision: '',
                    audience: '',
                    revenue: '',
                    goals: ''
                },
                research: {
                    scans: [],
                    currentScan: null
                },
                products: [],
                content: [],
                promotions: {
                    campaigns: [],
                    affiliates: []
                },
                canvas: {
                    content: '',
                    title: 'Business Canvas'
                },
                activity: [],
                settings: {
                    autoSaveInterval: 30
                }
            };
        }
        
        let state = getDefaultState();
        
        function loadState() {
            try {
                const saved = localStorage.getItem(STORAGE_KEY);
                if (saved) {
                    const parsed = JSON.parse(saved);
                    // Merge with defaults for any new fields
                    const defaults = getDefaultState();
                    state = { ...defaults, ...parsed };
                    
                    // Ensure arrays exist
                    if (!Array.isArray(state.research.scans)) state.research.scans = [];
                    if (!Array.isArray(state.products)) state.products = [];
                    if (!Array.isArray(state.content)) state.content = [];
                    if (!Array.isArray(state.promotions.campaigns)) state.promotions.campaigns = [];
                    if (!Array.isArray(state.promotions.affiliates)) state.promotions.affiliates = [];
                    if (!Array.isArray(state.activity)) state.activity = [];
                }
            } catch (e) {
                console.error('Error loading state:', e);
                state = getDefaultState();
            }
        }
        
        function saveState() {
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
            } catch (e) {
                console.error('Error saving state:', e);
            }
        }
        
        // ==========================================
        // Toast Notifications
        // ==========================================
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            
            const icons = {
                info: 'fa-info-circle',
                success: 'fa-check-circle',
                error: 'fa-exclamation-circle'
            };
            
            toast.innerHTML = `
                <i class="fas ${icons[type] || icons.info}"></i>
                <span>${message}</span>
            `;
            
            container.appendChild(toast);
            
            // Remove after 4 seconds
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }
        
        // ==========================================
        // Activity Logging
        // ==========================================
        function logActivity(action, details = '') {
            const activity = {
                timestamp: new Date().toISOString(),
                action,
                details,
                icon: getActivityIcon(action)
            };
            
            state.activity.unshift(activity);
            
            // Keep only last 50 activities
            if (state.activity.length > 50) {
                state.activity = state.activity.slice(0, 50);
            }
            
            saveState();
            updateActivityList();
        }
        
        function getActivityIcon(action) {
            const icons = {
                'login': 'fa-sign-in-alt',
                'logout': 'fa-sign-out-alt',
                'blueprint': 'fa-project-diagram',
                'research': 'fa-search',
                'product': 'fa-box-open',
                'content': 'fa-pen-fancy',
                'promotion': 'fa-bullhorn',
                'export': 'fa-download',
                'save': 'fa-save',
                'delete': 'fa-trash'
            };
            
            for (const [key, icon] of Object.entries(icons)) {
                if (action.toLowerCase().includes(key)) {
                    return icon;
                }
            }
            
            return 'fa-info-circle';
        }
        
        function updateActivityList() {
            const container = document.getElementById('activityList');
            if (!container) return;
            
            if (state.activity.length === 0) {
                container.innerHTML = `
                    <div class="activity-item">
                        <i class="fas fa-info-circle activity-icon"></i>
                        <div class="activity-content">
                            <div>No activity yet</div>
                            <div class="activity-time">Start using the system</div>
                        </div>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = state.activity.map(item => {
                const time = new Date(item.timestamp);
                const timeStr = time.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                const dateStr = time.toLocaleDateString([], { month: 'short', day: 'numeric' });
                
                return `
                    <div class="activity-item">
                        <i class="fas ${item.icon} activity-icon"></i>
                        <div class="activity-content">
                            <div>${item.action}</div>
                            <div class="activity-time">${dateStr} at ${timeStr}</div>
                        </div>
                    </div>
                `;
            }).join('');
        }
        
        // ==========================================
        // Dashboard Updates
        // ==========================================
        function updateDashboardStats() {
            // Blueprint completion
            const bpFields = Object.values(state.blueprint);
            const bpFilled = bpFields.filter(v => v && v.trim() !== '').length;
            const bpTotal = bpFields.length;
            const bpPercent = bpTotal > 0 ? Math.round((bpFilled / bpTotal) * 100) : 0;
            
            document.getElementById('stat-blueprint').textContent = `${bpPercent}%`;
            document.querySelector('#stat-blueprint').nextElementSibling.textContent = 
                bpPercent >= 80 ? 'Complete' : bpPercent >= Michel
